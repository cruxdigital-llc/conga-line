set -euxo pipefail
CONTAINER_ID="{{.ContainerID}}"

echo "=== Removing agent: $CONTAINER_ID ==="

systemctl stop conga-$CONTAINER_ID || true
systemctl disable conga-$CONTAINER_ID || true
rm -f /etc/systemd/system/conga-$CONTAINER_ID.service
systemctl daemon-reload
docker network rm conga-$CONTAINER_ID || true

echo "=== Agent $CONTAINER_ID removed from instance ==="
