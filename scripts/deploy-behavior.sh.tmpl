#!/bin/bash
set -euo pipefail

AGENT_NAME="$1"
AGENT_TYPE="$2"
STAGING="/opt/conga/behavior"
WORKSPACE="/opt/conga/data/$AGENT_NAME/data/workspace"

# Read Slack identifier for template substitution
SLACK_ID=$(cat "/opt/conga/config/$AGENT_NAME.slack-id" 2>/dev/null || echo "")

AGENT_DIR="$STAGING/agents/$AGENT_NAME"
DEFAULT_DIR="$STAGING/default"

# --- SOUL.md: agent-specific > default ---
if [ -f "$AGENT_DIR/SOUL.md" ]; then
  cp "$AGENT_DIR/SOUL.md" "$WORKSPACE/SOUL.md"
elif [ -f "$DEFAULT_DIR/SOUL.md" ]; then
  cp "$DEFAULT_DIR/SOUL.md" "$WORKSPACE/SOUL.md"
fi

# --- AGENTS.md: agent-specific > default ---
if [ -f "$AGENT_DIR/AGENTS.md" ]; then
  cp "$AGENT_DIR/AGENTS.md" "$WORKSPACE/AGENTS.md"
elif [ -f "$DEFAULT_DIR/AGENTS.md" ]; then
  cp "$DEFAULT_DIR/AGENTS.md" "$WORKSPACE/AGENTS.md"
fi

# --- USER.md: agent-specific > render type-specific template from default/ ---
if [ -f "$AGENT_DIR/USER.md" ]; then
  cp "$AGENT_DIR/USER.md" "$WORKSPACE/USER.md"
elif [ -f "$DEFAULT_DIR/$AGENT_TYPE/USER.md.tmpl" ]; then
  sed -e "s|{{.AgentName}}|$AGENT_NAME|g" \
      -e "s|{{AGENT_NAME}}|$AGENT_NAME|g" \
      -e "s|{{.SlackChannel}}|$SLACK_ID|g" \
      -e "s|{{.SlackMemberID}}|$SLACK_ID|g" \
      "$DEFAULT_DIR/$AGENT_TYPE/USER.md.tmpl" > "$WORKSPACE/USER.md"
fi

# Fix ownership — container runs as uid 1000 (node)
chown 1000:1000 "$WORKSPACE/SOUL.md" "$WORKSPACE/AGENTS.md" "$WORKSPACE/USER.md" 2>/dev/null || true

echo "Behavior files deployed for $AGENT_NAME ($AGENT_TYPE)"
