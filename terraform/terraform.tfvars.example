# AWS Configuration
aws_region   = "us-east-2"
aws_profile  = "your-aws-profile"
project_name = "conga-line"

# Instance — size at ~2GB per agent (r6g.medium = 8GB for up to 3 agents)
instance_type = "r6g.medium"

# Monitoring
config_check_interval_minutes = 5
alert_email = ""  # Set to receive alert emails

# Setup manifest — defines what config and secrets `conga admin setup` prompts for.
# The defaults cover a standard Slack deployment. Override to add/remove items.
#
# setup_manifest = {
#   config = {
#     "image" = "Docker image for OpenClaw (ECR, GHCR, or Docker Hub)"
#   }
#   secrets = {
#     "conga/shared/slack-bot-token"      = "Slack bot token (xoxb-)"
#     "conga/shared/slack-app-token"      = "Slack app token (xapp-)"
#     "conga/shared/slack-signing-secret" = "Slack signing secret"
#     "conga/shared/google-client-id"     = "Google OAuth client ID"
#     "conga/shared/google-client-secret" = "Google OAuth client secret"
#   }
# }
