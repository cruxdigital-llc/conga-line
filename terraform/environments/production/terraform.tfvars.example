# --- AWS ---
aws_region   = "us-east-2"
aws_profile  = "openclaw"
project_name = "conga-line"

# Path to repo root (for behavior files, router source, etc.)
repo_root = "/path/to/congaline"

# --- Infrastructure ---
instance_type = "r6g.medium"
alert_email   = ""

# --- Agents ---
# Define your fleet. Key is the agent name.
# Ports auto-assigned alphabetically from 18789 if omitted.
agents = {
  aaron = {
    type       = "user"
    binding_id = "UA13HEGTS"     # Slack member ID
  }
  zach = {
    type       = "user"
    binding_id = "U01UNLBCWNR"
  }
  nathan = {
    type       = "user"
    binding_id = "U05926LNP37"
  }
  nextgen-delivery = {
    type       = "team"
    binding_id = "C0AFBSMHQ15"  # Slack channel ID
  }
}

# --- Secrets ---
anthropic_api_key    = ""
slack_bot_token      = ""
slack_signing_secret = ""
slack_app_token      = ""

# Optional: extra per-agent secrets
# extra_secrets = {
#   aaron = {
#     "trello-api-key" = "..."
#     "trello-token"   = "..."
#   }
# }

# --- Egress Policy ---
egress_allowed_domains = ["api.anthropic.com", "*.slack.com", "*.slack-edge.com"]

# Optional: per-agent egress overrides
# agent_egress_overrides = {
#   aaron = ["api.anthropic.com", "*.slack.com", "*.slack-edge.com", "*.trello.com"]
# }
