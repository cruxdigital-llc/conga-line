#!/bin/bash
set -uo pipefail

# Log to file and stdout — capture tee PID so we can clean it up on exit
exec > >(tee /var/log/conga-bootstrap.log) 2>&1
TEE_PID=$!
trap 'kill $TEE_PID 2>/dev/null; wait $TEE_PID 2>/dev/null' EXIT
echo "=== Conga Bootstrap Start: $(date -u) ==="

AWS_REGION="${aws_region}"
PROJECT_NAME="${project_name}"
umask 077

# ============================================================
# 1. OS HARDENING
# ============================================================

dnf remove -y openssh-server || true

dnf install -y dnf-automatic
sed -i 's/apply_updates = no/apply_updates = yes/' /etc/dnf/automatic.conf
systemctl enable --now dnf-automatic-install.timer

cat > /etc/sysctl.d/99-conga.conf << 'SYSCTL'
net.ipv4.conf.all.send_redirects = 0
net.ipv4.conf.default.send_redirects = 0
net.ipv4.conf.all.accept_redirects = 0
net.ipv4.conf.default.accept_redirects = 0
net.ipv4.tcp_syncookies = 1
net.ipv6.conf.all.disable_ipv6 = 1
net.ipv6.conf.default.disable_ipv6 = 1
SYSCTL
sysctl --system

# ============================================================
# 2. INSTALL DOCKER + NODE.JS + JQ
# ============================================================

dnf install -y docker nodejs npm jq
useradd -m -s /bin/bash conga || true
usermod -aG docker conga
systemctl enable --now docker

echo "Docker, Node.js, and jq installed"

# ============================================================
# 2b. MOUNT PERSISTENT DATA VOLUME
# ============================================================

DATA_DEVICE="/dev/xvdf"
DATA_MOUNT="/opt/conga/data"

while [ ! -b "$DATA_DEVICE" ]; do
  echo "Waiting for data volume to attach..."
  sleep 5
done

if ! blkid "$DATA_DEVICE" | grep -q ext4; then
  echo "Formatting data volume (first time only)"
  mkfs.ext4 "$DATA_DEVICE"
fi

mkdir -p "$DATA_MOUNT"
mountpoint -q "$DATA_MOUNT" || mount "$DATA_DEVICE" "$DATA_MOUNT"

if ! grep -q "$DATA_DEVICE" /etc/fstab; then
  echo "$DATA_DEVICE $DATA_MOUNT ext4 defaults,nofail 0 2" >> /etc/fstab
fi

echo "Data volume mounted at $DATA_MOUNT"

# ============================================================
# 3. SHARED SECRETS
# ============================================================

get_secret() {
  local value
  value=$(aws secretsmanager get-secret-value \
    --secret-id "$1" \
    --query SecretString \
    --output text \
    --region "$AWS_REGION" 2>/dev/null) || true
  echo "$value"
}

# Validate shared secrets — fail fast if admin setup hasn't been run
validate_shared_secrets() {
  local missing=""
  [ -z "$SLACK_BOT_TOKEN" ] && missing="$missing slack-bot-token"
  [ -z "$SLACK_SIGNING_SECRET" ] && missing="$missing slack-signing-secret"
  if [ -n "$missing" ]; then
    echo "FATAL: Required shared secrets not found:$missing"
    echo "Run 'conga admin setup' before cycling the host."
    exit 1
  fi
}

SLACK_BOT_TOKEN=$(get_secret "conga/shared/slack-bot-token")
SLACK_APP_TOKEN=$(get_secret "conga/shared/slack-app-token")
SLACK_SIGNING_SECRET=$(get_secret "conga/shared/slack-signing-secret")
GOOGLE_CLIENT_ID=$(get_secret "conga/shared/google-client-id")
GOOGLE_CLIENT_SECRET=$(get_secret "conga/shared/google-client-secret")

validate_shared_secrets
echo "Shared secrets fetched"

# ============================================================
# 4. PULL CONGA IMAGE FROM ECR
# ============================================================

CONGA_IMAGE=$(aws ssm get-parameter --name "/conga/config/image" \
  --query "Parameter.Value" --output text --region "$AWS_REGION")

# Auto-login to ECR if image is from ECR
ECR_DOMAIN=$(echo "$CONGA_IMAGE" | cut -d'/' -f1)
if [[ "$ECR_DOMAIN" == *".dkr.ecr."* ]]; then
  aws ecr get-login-password --region "$AWS_REGION" | docker login --username AWS --password-stdin "$ECR_DOMAIN"
fi

docker pull "$CONGA_IMAGE"
docker pull node:22-alpine

mkdir -p /opt/conga/{bin,config,scripts,router/src}

echo "Conga image pulled"

# ============================================================
# 5. SETUP ROUTER
# ============================================================

# Download router source from S3
aws s3 cp s3://${state_bucket}/conga/router/package.json /opt/conga/router/package.json --region "$AWS_REGION"
aws s3 cp s3://${state_bucket}/conga/router/src/index.js /opt/conga/router/src/index.js --region "$AWS_REGION"

# Download behavior files from S3
aws s3 sync s3://${state_bucket}/conga/behavior/ /opt/conga/behavior/ --region "$AWS_REGION"

# Download policy file from S3 (if uploaded by operator)
aws s3 cp s3://${state_bucket}/conga/conga-policy.yaml /opt/conga/conga-policy.yaml --region "$AWS_REGION" 2>/dev/null || true

# Install router dependencies
cd /opt/conga/router && npm install --production
cd /

# --- Boot-time image refresh service ---
# Runs on every boot to pull the latest image from SSM before agents start
cat > /opt/conga/bin/refresh-image.sh << 'IMGREFRESH'
#!/bin/bash
set -euo pipefail
REGION=$(ec2-metadata --availability-zone 2>/dev/null | awk '{print substr($2,1,length($2)-1)}')
IMG=$(aws ssm get-parameter --name "/conga/config/image" \
  --query "Parameter.Value" --output text --region "$REGION" 2>/dev/null) || true
if [ -n "$IMG" ]; then
  # Auto-login to ECR if needed
  ECR_DOMAIN=$(echo "$IMG" | cut -d'/' -f1)
  if [[ "$ECR_DOMAIN" == *".dkr.ecr."* ]]; then
    aws ecr get-login-password --region "$REGION" | docker login --username AWS --password-stdin "$ECR_DOMAIN" 2>/dev/null || true
  fi
  docker pull "$IMG"
  # Update all agent systemd units with the current image
  CHANGED=false
  for UNIT in /etc/systemd/system/conga-*.service; do
    [ -f "$UNIT" ] || continue
    case "$(basename "$UNIT")" in
      conga-router.service|conga-image-refresh.service|conga-config-check.service|conga-session-metrics.service) continue ;;
    esac
    if grep -q "ExecStart=" "$UNIT" && ! grep -q "$IMG" "$UNIT"; then
      ESCAPED_IMG=$(printf '%s\n' "$IMG" | sed 's/[&/\]/\\&/g')
      sed -i "s|\(ExecStart=.* \)[^ ]*$|\1$ESCAPED_IMG|" "$UNIT"
      CHANGED=true
    fi
  done
  if [ "$CHANGED" = true ]; then
    systemctl daemon-reload
  fi
fi
IMGREFRESH
chmod +x /opt/conga/bin/refresh-image.sh

cat > /etc/systemd/system/conga-image-refresh.service << 'IMGUNIT'
[Unit]
Description=Refresh Conga image from SSM on boot
After=docker.service
Requires=docker.service
Before=conga-router.service

[Service]
Type=oneshot
ExecStart=/opt/conga/bin/refresh-image.sh
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
IMGUNIT
systemctl enable conga-image-refresh.service

# routing.json will be generated after agent discovery (section 6)

# Router env file
cat > /opt/conga/config/router.env << ROUTERENV
SLACK_APP_TOKEN=$SLACK_APP_TOKEN
SLACK_BOT_TOKEN=$SLACK_BOT_TOKEN
SLACK_SIGNING_SECRET=$SLACK_SIGNING_SECRET
ROUTER_CONFIG=/opt/conga/config/routing.json
ROUTERENV
chmod 0400 /opt/conga/config/router.env

# Router systemd unit
cat > /etc/systemd/system/conga-router.service << 'ROUTERUNIT'
[Unit]
Description=Conga Slack Event Router
After=docker.service
Requires=docker.service

[Service]
Type=simple
EnvironmentFile=/opt/conga/config/router.env
ExecStartPre=-/usr/bin/docker rm -f conga-router
ExecStart=/usr/bin/docker run --name conga-router --cap-drop ALL --security-opt no-new-privileges --memory 128m --cpus 0.25 --pids-limit 64 --read-only -v /opt/conga/router:/app:ro -v /opt/conga/config/routing.json:/opt/conga/config/routing.json:ro -e SLACK_APP_TOKEN -e SLACK_BOT_TOKEN -e SLACK_SIGNING_SECRET -e ROUTER_CONFIG=/opt/conga/config/routing.json node:22-alpine node /app/src/index.js
ExecStop=/usr/bin/docker stop conga-router
StandardOutput=append:/var/log/conga-router.log
StandardError=append:/var/log/conga-router.log
Restart=always
RestartSec=5
TimeoutStartSec=60

[Install]
WantedBy=multi-user.target
ROUTERUNIT

echo "Router configured"

# Download behavior deployment helper from S3 (canonical source: cli/scripts/deploy-behavior.sh.tmpl)
aws s3 cp s3://${state_bucket}/conga/scripts/deploy-behavior.sh /opt/conga/bin/deploy-behavior.sh --region "$AWS_REGION"
chmod +x /opt/conga/bin/deploy-behavior.sh

# ============================================================
# 6. DISCOVER AND SETUP AGENTS FROM SSM
# ============================================================

# --- Agent setup functions ---

setup_user_agent() {
  local AGENT_NAME="$1" SLACK_MEMBER_ID="$2" GATEWAY_PORT="$3"

  echo "  Setting up user agent: $AGENT_NAME (slack_member_id: $SLACK_MEMBER_ID, port: $GATEWAY_PORT)"

  # Discover per-agent secrets
  AGENT_SECRET_NAMES=$(aws secretsmanager list-secrets \
    --filter Key=name,Values="conga/agents/$AGENT_NAME/" \
    --query 'SecretList[].Name' --output text \
    --region "$AWS_REGION" 2>/dev/null || echo "")

  # Build env file
  cat > /opt/conga/config/$AGENT_NAME.env << ENVFILE
SLACK_BOT_TOKEN=$SLACK_BOT_TOKEN
SLACK_SIGNING_SECRET=$SLACK_SIGNING_SECRET
GOOGLE_CLIENT_ID=$GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=$GOOGLE_CLIENT_SECRET
ENVFILE

  if [ -n "$AGENT_SECRET_NAMES" ]; then
    for SECRET_PATH in $AGENT_SECRET_NAMES; do
      SECRET_VALUE=$(get_secret "$SECRET_PATH")
      SECRET_NAME=$(echo "$SECRET_PATH" | sed "s|conga/agents/$AGENT_NAME/||" | tr '[:lower:]-' '[:upper:]_')
      echo "$SECRET_NAME=$SECRET_VALUE" >> /opt/conga/config/$AGENT_NAME.env
    done
  fi
  chmod 0400 /opt/conga/config/$AGENT_NAME.env

  # Generate user-type openclaw.json (DM-only, restricted to owning user)
  # NOTE: Static config structure (model, heartbeat, pruning, etc.) is canonically defined in
  # cli/internal/common/openclaw-defaults.json — keep this heredoc in sync when updating.
  cat > /opt/conga/config/$AGENT_NAME-config.json << OCCONFIG
{
  "agents": {
    "defaults": {
      "model": { "primary": "anthropic/claude-opus-4-6", "fallbacks": [] },
      "models": { "anthropic/claude-opus-4-6": { "params": {} } },
      "workspace": "/home/node/.openclaw/data/workspace",
      "heartbeat": {
        "every": "55m",
        "lightContext": true,
        "target": "none"
      },
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "5m"
      },
      "compaction": {
        "mode": "safeguard"
      }
    }
  },
  "tools": { "profile": "coding" },
  "commands": { "native": "auto", "nativeSkills": "auto", "restart": true, "ownerDisplay": "raw" },
  "session": { "dmScope": "per-channel-peer" },
  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "command-logger": { "enabled": true },
        "session-memory": { "enabled": true }
      }
    }
  },
  "channels": {
    "slack": {
      "mode": "http",
      "enabled": true,
      "botToken": "$SLACK_BOT_TOKEN",
      "signingSecret": "$SLACK_SIGNING_SECRET",
      "webhookPath": "/slack/events",
      "userTokenReadOnly": true,
      "groupPolicy": "disabled",
      "dmPolicy": "allowlist",
      "allowFrom": ["$SLACK_MEMBER_ID"],
      "dm": { "enabled": true },
      "streaming": "partial",
      "nativeStreaming": true
    }
  },
  "gateway": { "port": 18789, "mode": "local", "bind": "lan", "controlUi": { "allowedOrigins": ["http://localhost:$GATEWAY_PORT"] } },
  "skills": { "install": { "nodeManager": "pnpm" } },
  "plugins": { "entries": { "slack": { "enabled": true } } }
}
OCCONFIG

  echo "$SLACK_MEMBER_ID" > /opt/conga/config/$AGENT_NAME.slack-id
  setup_agent_common "$AGENT_NAME" "$GATEWAY_PORT" "user"
}

setup_team_agent() {
  local AGENT_NAME="$1" SLACK_CHANNEL="$2" GATEWAY_PORT="$3"

  echo "  Setting up team agent: $AGENT_NAME (channel: $SLACK_CHANNEL, port: $GATEWAY_PORT)"

  # Discover per-agent secrets
  AGENT_SECRET_NAMES=$(aws secretsmanager list-secrets \
    --filter Key=name,Values="conga/agents/$AGENT_NAME/" \
    --query 'SecretList[].Name' --output text \
    --region "$AWS_REGION" 2>/dev/null || echo "")

  # Build env file
  cat > /opt/conga/config/$AGENT_NAME.env << ENVFILE
SLACK_BOT_TOKEN=$SLACK_BOT_TOKEN
SLACK_SIGNING_SECRET=$SLACK_SIGNING_SECRET
GOOGLE_CLIENT_ID=$GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=$GOOGLE_CLIENT_SECRET
ENVFILE

  if [ -n "$AGENT_SECRET_NAMES" ]; then
    for SECRET_PATH in $AGENT_SECRET_NAMES; do
      SECRET_VALUE=$(get_secret "$SECRET_PATH")
      SECRET_NAME=$(echo "$SECRET_PATH" | sed "s|conga/agents/$AGENT_NAME/||" | tr '[:lower:]-' '[:upper:]_')
      echo "$SECRET_NAME=$SECRET_VALUE" >> /opt/conga/config/$AGENT_NAME.env
    done
  fi
  chmod 0400 /opt/conga/config/$AGENT_NAME.env

  # Generate team-type openclaw.json (channel-based, anyone in channel)
  # NOTE: Static config structure (model, heartbeat, pruning, etc.) is canonically defined in
  # cli/internal/common/openclaw-defaults.json — keep this heredoc in sync when updating.
  cat > /opt/conga/config/$AGENT_NAME-config.json << OCCONFIG
{
  "agents": {
    "defaults": {
      "model": { "primary": "anthropic/claude-opus-4-6", "fallbacks": [] },
      "models": { "anthropic/claude-opus-4-6": { "params": {} } },
      "workspace": "/home/node/.openclaw/data/workspace",
      "heartbeat": {
        "every": "55m",
        "lightContext": true,
        "target": "none"
      },
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "5m"
      },
      "compaction": {
        "mode": "safeguard"
      }
    }
  },
  "tools": { "profile": "coding" },
  "commands": { "native": "auto", "nativeSkills": "auto", "restart": true, "ownerDisplay": "raw" },
  "session": { "dmScope": "per-channel-peer" },
  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "command-logger": { "enabled": true },
        "session-memory": { "enabled": true }
      }
    }
  },
  "channels": {
    "slack": {
      "mode": "http",
      "enabled": true,
      "botToken": "$SLACK_BOT_TOKEN",
      "signingSecret": "$SLACK_SIGNING_SECRET",
      "webhookPath": "/slack/events",
      "userTokenReadOnly": true,
      "groupPolicy": "allowlist",
      "dmPolicy": "disabled",
      "streaming": "partial",
      "nativeStreaming": true,
      "channels": { "$SLACK_CHANNEL": { "allow": true, "requireMention": false } }
    }
  },
  "gateway": { "port": 18789, "mode": "local", "bind": "lan", "controlUi": { "allowedOrigins": ["http://localhost:$GATEWAY_PORT"] } },
  "skills": { "install": { "nodeManager": "pnpm" } },
  "plugins": { "entries": { "slack": { "enabled": true } } }
}
OCCONFIG

  echo "$SLACK_CHANNEL" > /opt/conga/config/$AGENT_NAME.slack-id
  setup_agent_common "$AGENT_NAME" "$GATEWAY_PORT" "team"
}

# Generate Envoy egress conf from conga-policy.yaml for a given agent.
# Reads global allowed_domains and agent-specific overrides.
# Output: /opt/conga/config/egress-$AGENT_NAME.yaml
#
# When mode is "enforce", iptables DROP rules are applied via ExecStartPost in the
# systemd unit and cleaned up via ExecStopPost. In validate mode, the Envoy proxy
# logs would-be-denied requests but does not block traffic or apply iptables rules.
generate_egress_conf() {
  # NOTE: This function generates the same Envoy config format as the template
  # in cli/internal/policy/templates/envoy-config.yaml.tmpl — keep both in sync.
  local AGENT_NAME="$1"
  local POLICY_FILE="/opt/conga/conga-policy.yaml"
  local CONF_OUT="/opt/conga/config/egress-$AGENT_NAME.yaml"

  local DOMAINS=""
  local EFFECTIVE_MODE="enforce"

  if [ ! -f "$POLICY_FILE" ]; then
    # No policy file — deny-all config (empty allowlist)
    log "No egress policy for $AGENT_NAME — generating deny-all config"
  else

  # Extract allowed_domains and blocked_domains — check agent override first, fall back to global.
  # Uses simple grep/sed since yq is not guaranteed on AL2023.
  local IN_AGENT_SECTION=false
  local IN_AGENT_EGRESS=false
  local IN_AGENT_ALLOWED=false
  local IN_AGENT_BLOCKED=false
  local IN_GLOBAL_EGRESS=false
  local IN_GLOBAL_ALLOWED=false
  local IN_GLOBAL_BLOCKED=false
  local AGENT_ALLOWED=""
  local AGENT_BLOCKED=""
  local GLOBAL_ALLOWED=""
  local GLOBAL_BLOCKED=""
  local GLOBAL_MODE=""
  local AGENT_MODE=""

  while IFS= read -r line; do
    # Detect agent-specific section
    if echo "$line" | grep -qE "^  $AGENT_NAME:"; then
      IN_AGENT_SECTION=true
      IN_AGENT_EGRESS=false
      IN_AGENT_ALLOWED=false
      IN_AGENT_BLOCKED=false
      continue
    fi
    # Detect next agent or top-level key (end of agent section)
    if $IN_AGENT_SECTION && echo "$line" | grep -qE "^  [a-zA-Z]" && ! echo "$line" | grep -qE "^    "; then
      IN_AGENT_SECTION=false
      IN_AGENT_EGRESS=false
      IN_AGENT_ALLOWED=false
      IN_AGENT_BLOCKED=false
    fi
    # Detect agent egress subsection
    if $IN_AGENT_SECTION && echo "$line" | grep -qE "^    egress:"; then
      IN_AGENT_EGRESS=true
      IN_AGENT_ALLOWED=false
      IN_AGENT_BLOCKED=false
      continue
    fi
    if $IN_AGENT_EGRESS && echo "$line" | grep -qE "^    [a-z]" && ! echo "$line" | grep -qE "^      "; then
      IN_AGENT_EGRESS=false
      IN_AGENT_ALLOWED=false
      IN_AGENT_BLOCKED=false
    fi
    # Detect allowed_domains vs blocked_domains within agent egress
    if $IN_AGENT_EGRESS && echo "$line" | grep -qE "^      allowed_domains:"; then
      IN_AGENT_ALLOWED=true
      IN_AGENT_BLOCKED=false
      continue
    fi
    if $IN_AGENT_EGRESS && echo "$line" | grep -qE "^      blocked_domains:"; then
      IN_AGENT_BLOCKED=true
      IN_AGENT_ALLOWED=false
      continue
    fi
    if $IN_AGENT_EGRESS && echo "$line" | grep -qE "^      [a-z]" && ! echo "$line" | grep -qE "^        "; then
      IN_AGENT_ALLOWED=false
      IN_AGENT_BLOCKED=false
    fi
    # Collect agent allowed domains
    if $IN_AGENT_ALLOWED && echo "$line" | grep -qE "^        - "; then
      local d
      d=$(echo "$line" | sed 's/^        - //; s/^"//; s/"$//' | tr -d "'" | xargs)
      [ -n "$d" ] && AGENT_ALLOWED="$AGENT_ALLOWED $d"
    fi
    # Collect agent blocked domains
    if $IN_AGENT_BLOCKED && echo "$line" | grep -qE "^        - "; then
      local d
      d=$(echo "$line" | sed 's/^        - //; s/^"//; s/"$//' | tr -d "'" | xargs)
      [ -n "$d" ] && AGENT_BLOCKED="$AGENT_BLOCKED $d"
    fi
    # Detect agent egress mode
    if $IN_AGENT_EGRESS && echo "$line" | grep -qE "^      mode:"; then
      AGENT_MODE=$(echo "$line" | sed 's/^      mode: *//' | tr -d '"' | tr -d "'" | xargs)
    fi

    # Detect global egress section
    if echo "$line" | grep -qE "^egress:"; then
      IN_GLOBAL_EGRESS=true
      IN_GLOBAL_ALLOWED=false
      IN_GLOBAL_BLOCKED=false
      continue
    fi
    if $IN_GLOBAL_EGRESS && echo "$line" | grep -qE "^[a-z]"; then
      IN_GLOBAL_EGRESS=false
      IN_GLOBAL_ALLOWED=false
      IN_GLOBAL_BLOCKED=false
    fi
    # Detect allowed_domains vs blocked_domains within global egress
    if $IN_GLOBAL_EGRESS && echo "$line" | grep -qE "^  allowed_domains:"; then
      IN_GLOBAL_ALLOWED=true
      IN_GLOBAL_BLOCKED=false
      continue
    fi
    if $IN_GLOBAL_EGRESS && echo "$line" | grep -qE "^  blocked_domains:"; then
      IN_GLOBAL_BLOCKED=true
      IN_GLOBAL_ALLOWED=false
      continue
    fi
    if $IN_GLOBAL_EGRESS && echo "$line" | grep -qE "^  [a-z]" && ! echo "$line" | grep -qE "^    "; then
      IN_GLOBAL_ALLOWED=false
      IN_GLOBAL_BLOCKED=false
    fi
    # Collect global allowed domains
    if $IN_GLOBAL_ALLOWED && echo "$line" | grep -qE "^    - "; then
      local d
      d=$(echo "$line" | sed 's/^    - //; s/^"//; s/"$//' | tr -d "'" | xargs)
      [ -n "$d" ] && GLOBAL_ALLOWED="$GLOBAL_ALLOWED $d"
    fi
    # Collect global blocked domains
    if $IN_GLOBAL_BLOCKED && echo "$line" | grep -qE "^    - "; then
      local d
      d=$(echo "$line" | sed 's/^    - //; s/^"//; s/"$//' | tr -d "'" | xargs)
      [ -n "$d" ] && GLOBAL_BLOCKED="$GLOBAL_BLOCKED $d"
    fi
    # Detect global egress mode
    if $IN_GLOBAL_EGRESS && echo "$line" | grep -qE "^  mode:"; then
      GLOBAL_MODE=$(echo "$line" | sed 's/^  mode: *//' | tr -d '"' | tr -d "'" | xargs)
    fi
  done < "$POLICY_FILE"

  # Agent override replaces global (shallow merge per spec)
  local ALLOWED="" BLOCKED=""
  if [ -n "$AGENT_ALLOWED" ]; then
    ALLOWED="$AGENT_ALLOWED"
    BLOCKED="$AGENT_BLOCKED"
  else
    ALLOWED="$GLOBAL_ALLOWED"
    BLOCKED="$GLOBAL_BLOCKED"
  fi

  # Resolve effective mode (agent override takes precedence, default is "enforce")
  if [ -n "$AGENT_ALLOWED" ]; then
    EFFECTIVE_MODE="$${AGENT_MODE:-$$GLOBAL_MODE}"
  else
    EFFECTIVE_MODE="$GLOBAL_MODE"
  fi
  EFFECTIVE_MODE="$${EFFECTIVE_MODE:-enforce}"

  # Remove blocked domains from allowed list
  if [ -n "$BLOCKED" ]; then
    local FILTERED=""
    for a in $ALLOWED; do
      local is_blocked=false
      a_lower=$(echo "$a" | tr '[:upper:]' '[:lower:]')
      for b in $BLOCKED; do
        b_lower=$(echo "$b" | tr '[:upper:]' '[:lower:]')
        if [ "$a_lower" = "$b_lower" ]; then
          is_blocked=true
          break
        fi
      done
      if ! $is_blocked; then
        FILTERED="$FILTERED $a"
      fi
    done
    ALLOWED="$FILTERED"
  fi

  # Apply effective domains from parsed policy
  DOMAINS=$(echo "$ALLOWED" | xargs) # trim
  if [ -z "$DOMAINS" ]; then
    # Sanity check: if the policy file mentions allowed_domains but we parsed zero,
    # the YAML structure may not match our grep/sed heuristics (e.g., tabs, anchors).
    if grep -q "allowed_domains:" "$POLICY_FILE" 2>/dev/null; then
      log "ERROR: Policy file contains allowed_domains but none were parsed for $AGENT_NAME — check YAML indentation. Refusing to start agent without egress protection."
      return 1
    fi
    log "No allowed domains in policy for $AGENT_NAME — generating deny-all config"
  fi

  fi # end of policy file exists block

  # Determine deny action based on mode
  # validate: log what would be denied but allow traffic through
  # enforce: return 403 to deny non-allowlisted traffic
  if [ "$EFFECTIVE_MODE" = "validate" ]; then
    log "Egress proxy for $AGENT_NAME in validate mode (logging only)."
    local DENY_ACTION='                    h:logWarn("egress-validate: would deny " .. host)'
    local MISSING_HOST_ACTION='                    if not m then h:logWarn("egress-validate: would deny (missing host)"); return end'
  else
    local DENY_ACTION='                    h:respond({[":status"] = "403"}, "egress denied: " .. host .. "\\n")'
    local MISSING_HOST_ACTION='                    if not m then h:respond({[":status"] = "403"}, "egress denied: missing host\\n"); return end'
  fi

  # Generate Envoy config with Lua-based domain filtering
  # Build Lua EXACT and SUFFIXES tables from domain list
  local EXACT_ENTRIES=""
  local SUFFIX_ENTRIES=""
  for d in $DOMAINS; do
    d=$(echo "$d" | tr '[:upper:]' '[:lower:]')
    case "$d" in
      \*.*)
        local base="$${d#\*.}"
        SUFFIX_ENTRIES="$${SUFFIX_ENTRIES}                    \".$${base}\",\n"
        ;;
      *)
        EXACT_ENTRIES="$${EXACT_ENTRIES}                    [\"$${d}\"] = true,\n"
        ;;
    esac
  done

  cat > "$CONF_OUT" << ENVOY_CONF
# Conga Line Egress Proxy — Envoy forward proxy with domain filtering
# Generated by bootstrap — do not edit manually
static_resources:
  listeners:
  - address:
      socket_address: { address: 0.0.0.0, port_value: 3128 }
    filter_chains:
    - filters:
      - name: envoy.filters.network.http_connection_manager
        typed_config:
          "@type": type.googleapis.com/envoy.extensions.filters.network.http_connection_manager.v3.HttpConnectionManager
          stat_prefix: egress
          http_protocol_options: {}
          upgrade_configs:
          - upgrade_type: CONNECT
          route_config:
            virtual_hosts:
            - name: all
              domains: ["*"]
              routes:
              - match: { connect_matcher: {} }
                route:
                  cluster: dynamic_forward_proxy
                  upgrade_configs:
                  - upgrade_type: CONNECT
                    connect_config: {}
              - match: { prefix: "/" }
                route: { cluster: dynamic_forward_proxy }
          http_filters:
          - name: envoy.filters.http.lua
            typed_config:
              "@type": type.googleapis.com/envoy.extensions.filters.http.lua.v3.Lua
              default_source_code:
                inline_string: |
                  local EXACT = {
$(echo -e "$EXACT_ENTRIES")                  }
                  local SUFFIXES = {
$(echo -e "$SUFFIX_ENTRIES")                  }
                  function envoy_on_request(h)
                    local a = h:headers():get(":authority") or ""
                    local m = a:match("^([^:]+)")
$MISSING_HOST_ACTION
                    local host = m:lower()
                    if EXACT[host] then return end
                    for _, s in ipairs(SUFFIXES) do
                      if host == s:sub(2) or host:sub(-#s) == s then return end
                    end
$DENY_ACTION
                  end
          - name: envoy.filters.http.dynamic_forward_proxy
            typed_config:
              "@type": type.googleapis.com/envoy.extensions.filters.http.dynamic_forward_proxy.v3.FilterConfig
              dns_cache_config:
                name: dns_cache
                dns_lookup_family: V4_ONLY
          - name: envoy.filters.http.router
            typed_config:
              "@type": type.googleapis.com/envoy.extensions.filters.http.router.v3.Router
  clusters:
  - name: dynamic_forward_proxy
    lb_policy: CLUSTER_PROVIDED
    cluster_type:
      name: envoy.clusters.dynamic_forward_proxy
      typed_config:
        "@type": type.googleapis.com/envoy.extensions.clusters.dynamic_forward_proxy.v3.ClusterConfig
        dns_cache_config:
          name: dns_cache
          dns_lookup_family: V4_ONLY
ENVOY_CONF

  chmod 0400 "$CONF_OUT"

  # Write mode marker so systemd hooks know whether to apply iptables
  echo "$EFFECTIVE_MODE" > "/opt/conga/config/egress-$AGENT_NAME.mode"
  log "Generated egress config for $AGENT_NAME (mode=$EFFECTIVE_MODE) with domains: $DOMAINS"
}

# Shared setup logic for both agent types
setup_agent_common() {
  local AGENT_NAME="$1" GATEWAY_PORT="$2" AGENT_TYPE="$3"

  # Store agent type for ExecStartPre behavior deployment
  echo "$AGENT_TYPE" > /opt/conga/config/$AGENT_NAME.type

  # Create persistent storage (always ensure data subdirs exist, even on re-provision)
  mkdir -p /opt/conga/data/$AGENT_NAME/data/{workspace,memory,logs,agents,canvas,cron,devices,identity,media}
  chown -R 1000:1000 /opt/conga/data/$AGENT_NAME
  cp /opt/conga/config/$AGENT_NAME-config.json /opt/conga/data/$AGENT_NAME/openclaw.json
  chown 1000:1000 /opt/conga/data/$AGENT_NAME/openclaw.json

  # Deploy behavior files (SOUL.md, AGENTS.md, USER.md) to workspace
  /opt/conga/bin/deploy-behavior.sh "$AGENT_NAME" "$AGENT_TYPE"
  # Re-chown workspace after behavior deployment (files created as root)
  chown -R 1000:1000 /opt/conga/data/$AGENT_NAME/data/workspace

  # Config hash baseline
  sha256sum /opt/conga/config/$AGENT_NAME-config.json | cut -d' ' -f1 > /opt/conga/config/$AGENT_NAME-config.json.sha256
  chmod 0444 /opt/conga/config/$AGENT_NAME-config.json.sha256

  # Docker network
  docker network create --driver bridge "conga-$AGENT_NAME" || true

  # Generate egress config from policy (deny-all when no policy exists)
  if ! generate_egress_conf "$AGENT_NAME"; then
    # Check if the policy specifies enforce mode — refuse to start without egress protection
    AGENT_EGRESS_MODE=$(cat "/opt/conga/config/egress-$AGENT_NAME.mode" 2>/dev/null || echo "")
    if [ -z "$AGENT_EGRESS_MODE" ]; then
      # Mode file not written (generate failed early) — check policy file directly
      AGENT_EGRESS_MODE=$(grep -A5 "^egress:" /opt/conga/conga-policy.yaml 2>/dev/null | grep "mode:" | head -1 | sed 's/.*mode: *//' | tr -d '"'"'" | xargs)
      AGENT_EGRESS_MODE="$${AGENT_EGRESS_MODE:-enforce}"
    fi
    if [ "$AGENT_EGRESS_MODE" = "enforce" ]; then
      log "FATAL: Egress config generation failed for $AGENT_NAME in enforce mode — refusing to start agent without egress protection"
      return 1
    fi
    log "WARNING: Egress config generation failed for $AGENT_NAME in validate mode — agent will start without egress filtering"
  fi

  # Per-agent egress proxy (when policy-generated config exists)
  EGRESS_CONF="/opt/conga/config/egress-$AGENT_NAME.yaml"
  EGRESS_PROXY="conga-egress-$AGENT_NAME"
  EGRESS_DOCKER_ARGS=""
  if [ -f "$EGRESS_CONF" ]; then
    log "Starting egress proxy for $AGENT_NAME..."
    # Build proxy image if not present (Envoy)
    if ! docker image inspect conga-egress-proxy >/dev/null 2>&1; then
      log "Building egress proxy image..."
      mkdir -p /tmp/conga-egress-build
      cat > /tmp/conga-egress-build/Dockerfile << 'PROXYDF'
FROM envoyproxy/envoy:v1.32-latest
PROXYDF
      if ! docker build -t conga-egress-proxy /tmp/conga-egress-build; then
        rm -rf /tmp/conga-egress-build
        AGENT_EGRESS_MODE=$(cat "/opt/conga/config/egress-$AGENT_NAME.mode" 2>/dev/null || echo "enforce")
        if [ "$AGENT_EGRESS_MODE" = "enforce" ]; then
          log "FATAL: Failed to build egress proxy image in enforce mode — refusing to start $AGENT_NAME without egress filtering"
          return 1
        fi
        log "WARNING: Failed to build egress proxy image — $AGENT_NAME will run without egress filtering (validate mode)"
        EGRESS_CONF=""
      fi
      rm -rf /tmp/conga-egress-build
    fi
    if [ -n "$EGRESS_CONF" ]; then
    docker rm -f "$EGRESS_PROXY" 2>/dev/null || true
    docker run -d \
      --name "$EGRESS_PROXY" \
      --network "conga-$AGENT_NAME" \
      --restart always \
      --cap-drop ALL \
      --security-opt no-new-privileges \
      --memory 128m \
      --user 101:101 \
      --entrypoint '' \
      -v "$EGRESS_CONF:/etc/envoy/envoy.yaml:ro" \
      conga-egress-proxy \
      envoy -c /etc/envoy/envoy.yaml --log-level warn
    # Verify proxy started (retry to allow for slow starts on loaded hosts)
    for i in $(seq 1 5); do
      if docker inspect -f '{{.State.Running}}' "$EGRESS_PROXY" 2>/dev/null | grep -q true; then
        break
      fi
      sleep 1
    done
    if ! docker inspect -f '{{.State.Running}}' "$EGRESS_PROXY" 2>/dev/null | grep -q true; then
      docker logs "$EGRESS_PROXY" 2>&1 | tail -20 || true
      AGENT_EGRESS_MODE=$(cat "/opt/conga/config/egress-$AGENT_NAME.mode" 2>/dev/null || echo "enforce")
      if [ "$AGENT_EGRESS_MODE" = "enforce" ]; then
        log "FATAL: Egress proxy $EGRESS_PROXY failed to start in enforce mode — refusing to start $AGENT_NAME without egress filtering"
        return 1
      fi
      log "WARNING: Egress proxy $EGRESS_PROXY failed to start — $AGENT_NAME will run without egress filtering (validate mode)"
      EGRESS_DOCKER_ARGS=""
    else
    # Proxy is on the same Docker network — Docker DNS resolves the container name.
    EGRESS_DOCKER_ARGS="-e HTTPS_PROXY=http://$EGRESS_PROXY:3128 -e HTTP_PROXY=http://$EGRESS_PROXY:3128 -e NO_PROXY=localhost,127.0.0.1"
    # Write proxy bootstrap JS (patches Node.js fetch/https to route through proxy)
    # NOTE: This must match cli/internal/policy/templates/proxy-bootstrap.js — keep both in sync.
    BOOTSTRAP_PATH="/opt/conga/config/proxy-bootstrap.js"
    if [ ! -f "$BOOTSTRAP_PATH" ]; then
      cat > "$BOOTSTRAP_PATH" << 'BOOTSTRAPJS'
'use strict';
const proxyUrl = process.env.HTTPS_PROXY || process.env.HTTP_PROXY || process.env.__CONGA_PROXY_URL;
if (proxyUrl) {
  const http = require('http');
  const https = require('https');
  const tls = require('tls');
  const { URL } = require('url');
  if (!process.env.HTTPS_PROXY) process.env.HTTPS_PROXY = proxyUrl;
  const { EnvHttpProxyAgent, setGlobalDispatcher } = require('/app/node_modules/undici');
  setGlobalDispatcher(new EnvHttpProxyAgent());
  const parsed = new URL(proxyUrl);
  class ConnectProxyAgent extends https.Agent {
    constructor() { super({ keepAlive: true }); }
    createConnection(opts, cb) {
      const req = http.request({
        host: parsed.hostname, port: parsed.port, method: 'CONNECT',
        path: (opts.host || opts.hostname) + ':' + (opts.port || 443),
      });
      req.on('connect', (_res, socket) => {
        if (_res.statusCode !== 200) { cb(new Error('Proxy CONNECT failed: ' + _res.statusCode)); return; }
        const tlsSock = tls.connect({ socket: socket, servername: opts.host || opts.hostname }, () => cb(null, tlsSock));
        tlsSock.on('error', cb);
      });
      req.on('error', cb);
      req.end();
    }
  }
  https.globalAgent = new ConnectProxyAgent();
  process.env.__CONGA_PROXY_URL = proxyUrl;
  process.env.HTTPS_PROXY = proxyUrl;
  process.env.HTTP_PROXY = proxyUrl;
}
BOOTSTRAPJS
      chmod 0444 "$BOOTSTRAP_PATH"
    fi
    EGRESS_DOCKER_ARGS="$EGRESS_DOCKER_ARGS -v $BOOTSTRAP_PATH:/opt/proxy-bootstrap.js:ro"
    log "Egress proxy started for $AGENT_NAME"
    fi # proxy started successfully
    fi # EGRESS_CONF still set (build succeeded)
  fi

  # Build -e flags from env file keys
  ENV_FLAGS=""
  while IFS="=" read -r key value; do
    [ -n "$key" ] && ENV_FLAGS="$ENV_FLAGS -e $key"
  done < /opt/conga/config/$AGENT_NAME.env

  # Set NODE_OPTIONS — add proxy bootstrap require when egress is configured
  NODE_OPTS="--max-old-space-size=1536"
  if [ -f "/opt/conga/config/proxy-bootstrap.js" ] && [ -n "$EGRESS_DOCKER_ARGS" ]; then
    NODE_OPTS="$NODE_OPTS --require /opt/proxy-bootstrap.js"
  fi

  # Systemd unit — image written literally; updated on boot by conga-image-refresh.service
  cat > /etc/systemd/system/conga-$AGENT_NAME.service << UNIT
[Unit]
Description=Conga Gateway ($AGENT_NAME)
After=docker.service conga-router.service conga-image-refresh.service
Requires=docker.service

[Service]
Type=simple
EnvironmentFile=/opt/conga/config/$AGENT_NAME.env
ExecStartPre=/bin/bash -c 'aws s3 sync s3://${state_bucket}/conga/behavior/ /opt/conga/behavior/ --region ${aws_region} 2>/dev/null || true; /opt/conga/bin/deploy-behavior.sh $AGENT_NAME \$(cat /opt/conga/config/$AGENT_NAME.type 2>/dev/null || echo user) 2>/dev/null || true; chown -R 1000:1000 /opt/conga/data/$AGENT_NAME/data/workspace 2>/dev/null || true'
ExecStartPre=-/usr/bin/docker rm -f conga-$AGENT_NAME
ExecStart=/usr/bin/docker run --name conga-$AGENT_NAME --network conga-$AGENT_NAME -p 127.0.0.1:$GATEWAY_PORT:18789 --cap-drop ALL --security-opt no-new-privileges --memory 2g --cpus 0.75 -e NODE_OPTIONS="$NODE_OPTS" --pids-limit 256 -v /opt/conga/data/$AGENT_NAME:/home/node/.openclaw:rw $EGRESS_DOCKER_ARGS $ENV_FLAGS $CONGA_IMAGE
ExecStartPost=-/usr/bin/docker network connect conga-$AGENT_NAME conga-router
ExecStartPost=-/bin/bash -c 'MODE=\$(cat /opt/conga/config/egress-$AGENT_NAME.mode 2>/dev/null); if [ "\$MODE" = "enforce" ]; then AGENT_IP=\$(docker inspect -f "{{(index .NetworkSettings.Networks \"conga-$AGENT_NAME\").IPAddress}}" conga-$AGENT_NAME 2>/dev/null); NET_CIDR=\$(docker network inspect -f "{{range .IPAM.Config}}{{.Subnet}}{{end}}" conga-$AGENT_NAME 2>/dev/null); if [ -n "\$AGENT_IP" ] && [ -n "\$NET_CIDR" ]; then iptables -C DOCKER-USER -s \$AGENT_IP -j DROP 2>/dev/null || iptables -I DOCKER-USER -s \$AGENT_IP -j DROP || echo "WARNING: failed to add iptables DROP rule for conga-$AGENT_NAME (\$AGENT_IP)" >&2; iptables -C DOCKER-USER -s \$AGENT_IP -d \$NET_CIDR -j RETURN 2>/dev/null || iptables -I DOCKER-USER -s \$AGENT_IP -d \$NET_CIDR -j RETURN || echo "WARNING: failed to add iptables subnet RETURN rule for conga-$AGENT_NAME" >&2; iptables -C DOCKER-USER -s \$AGENT_IP -m conntrack --ctstate ESTABLISHED,RELATED -j RETURN 2>/dev/null || iptables -I DOCKER-USER -s \$AGENT_IP -m conntrack --ctstate ESTABLISHED,RELATED -j RETURN || echo "WARNING: failed to add iptables conntrack RETURN rule for conga-$AGENT_NAME" >&2; else echo "WARNING: egress iptables rules failed for conga-$AGENT_NAME — container IP (\$AGENT_IP) or subnet (\$NET_CIDR) not found" >&2; fi; fi'
ExecStopPost=-/bin/bash -c 'AGENT_IP=\$(docker inspect -f "{{(index .NetworkSettings.Networks \"conga-$AGENT_NAME\").IPAddress}}" conga-$AGENT_NAME 2>/dev/null); NET_CIDR=\$(docker network inspect -f "{{range .IPAM.Config}}{{.Subnet}}{{end}}" conga-$AGENT_NAME 2>/dev/null); if [ -n "\$AGENT_IP" ] && [ -n "\$NET_CIDR" ]; then iptables -D DOCKER-USER -s \$AGENT_IP -m conntrack --ctstate ESTABLISHED,RELATED -j RETURN 2>/dev/null || true; iptables -D DOCKER-USER -s \$AGENT_IP -d \$NET_CIDR -j RETURN 2>/dev/null || true; iptables -D DOCKER-USER -s \$AGENT_IP -j DROP 2>/dev/null || true; fi'
ExecStop=/usr/bin/docker stop conga-$AGENT_NAME
StandardOutput=append:/var/log/conga-$AGENT_NAME.log
StandardError=append:/var/log/conga-$AGENT_NAME.log
Restart=always
RestartSec=10
TimeoutStartSec=120
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
UNIT

  echo "  Agent $AGENT_NAME configured"
}

# --- Stop any existing agent containers from prior bootstraps ---
# Prevents port conflicts when agent names change (e.g. migration from member_id to name)

for OLD_UNIT in /etc/systemd/system/conga-*.service; do
  [ -f "$OLD_UNIT" ] || continue
  UNIT_NAME=$(basename "$OLD_UNIT" .service)
  case "$UNIT_NAME" in
    conga-router|conga-image-refresh|conga-config-check|conga-session-metrics) continue ;;
  esac
  echo "Stopping previous agent: $UNIT_NAME"
  # Clean up egress iptables rules before stopping (need container IP while running)
  AGENT_IP=$(docker inspect -f '{{range .NetworkSettings.Networks}}{{.IPAddress}}{{end}}' "$UNIT_NAME" 2>/dev/null || echo "")
  AGENT_NET="$${UNIT_NAME#conga-}"
  NET_CIDR=$(docker network inspect -f '{{range .IPAM.Config}}{{.Subnet}}{{end}}' "conga-$AGENT_NET" 2>/dev/null || echo "")
  if [ -n "$AGENT_IP" ] && [ -n "$NET_CIDR" ]; then
    iptables -D DOCKER-USER -s "$AGENT_IP" -m conntrack --ctstate ESTABLISHED,RELATED -j RETURN 2>/dev/null || true
    iptables -D DOCKER-USER -s "$AGENT_IP" -d "$NET_CIDR" -j RETURN 2>/dev/null || true
    iptables -D DOCKER-USER -s "$AGENT_IP" -j DROP 2>/dev/null || true
  fi
  systemctl stop "$UNIT_NAME" 2>/dev/null || true
  docker rm -f "$UNIT_NAME" 2>/dev/null || true
  systemctl disable "$UNIT_NAME" 2>/dev/null || true
  rm -f "$OLD_UNIT"
done
systemctl daemon-reload

# --- Discover all agents from SSM ---

AGENT_PARAMS=$(aws ssm get-parameters-by-path \
  --path "/conga/agents/" \
  --query "Parameters" \
  --output json --region "$AWS_REGION" 2>&1) || {
  echo "FATAL: Failed to query agents from SSM: $AGENT_PARAMS"
  echo "Check IAM permissions for ssm:GetParametersByPath on /conga/agents/"
  exit 1
}

ROUTING_CHANNELS="{}"
ROUTING_MEMBERS="{}"
ALL_AGENT_NAMES=""

for PARAM in $(echo "$AGENT_PARAMS" | jq -r '.[] | @base64'); do
  PARAM_JSON=$(echo "$PARAM" | base64 -d)
  AGENT_NAME=$(echo "$PARAM_JSON" | jq -r '.Name' | xargs basename)
  PARAM_VALUE=$(echo "$PARAM_JSON" | jq -r '.Value')
  AGENT_TYPE=$(echo "$PARAM_VALUE" | jq -r '.type // empty')
  GATEWAY_PORT=$(echo "$PARAM_VALUE" | jq -r '.gateway_port')

  if [ -z "$AGENT_TYPE" ]; then
    echo "WARNING: Agent $AGENT_NAME has no type field, skipping"
    continue
  fi

  AGENT_PAUSED=$(echo "$PARAM_VALUE" | jq -r '.paused // false')
  if [ "$AGENT_PAUSED" = "true" ]; then
    echo "=== Skipping paused agent: $AGENT_NAME ==="
    continue
  fi

  echo "=== Setting up agent: $AGENT_NAME (type: $AGENT_TYPE) ==="

  if [ "$AGENT_TYPE" = "user" ]; then
    SLACK_MEMBER_ID=$(echo "$PARAM_VALUE" | jq -r '.slack_member_id')
    setup_user_agent "$AGENT_NAME" "$SLACK_MEMBER_ID" "$GATEWAY_PORT"
    ROUTING_MEMBERS=$(echo "$ROUTING_MEMBERS" | jq \
      --arg k "$SLACK_MEMBER_ID" \
      --arg v "http://conga-$AGENT_NAME:18789/slack/events" \
      '. + {($k): $v}')
  elif [ "$AGENT_TYPE" = "team" ]; then
    SLACK_CHANNEL=$(echo "$PARAM_VALUE" | jq -r '.slack_channel')
    setup_team_agent "$AGENT_NAME" "$SLACK_CHANNEL" "$GATEWAY_PORT"
    ROUTING_CHANNELS=$(echo "$ROUTING_CHANNELS" | jq \
      --arg k "$SLACK_CHANNEL" \
      --arg v "http://conga-$AGENT_NAME:18789/slack/events" \
      '. + {($k): $v}')
  else
    echo "WARNING: Unknown agent type '$AGENT_TYPE' for $AGENT_NAME, skipping"
    continue
  fi

  ALL_AGENT_NAMES="$ALL_AGENT_NAMES $AGENT_NAME"
done

# Write routing.json
jq -n --argjson channels "$ROUTING_CHANNELS" --argjson members "$ROUTING_MEMBERS" \
  '{"channels": $channels, "members": $members}' > /opt/conga/config/routing.json

if [ -z "$(echo "$ALL_AGENT_NAMES" | tr -d ' ')" ]; then
  echo "WARNING: No agents found in SSM. Router will start with empty routing config."
fi

# --- Install dashboard update helper ---
# Called by bootstrap and by CLI add-user/add-team scripts
mkdir -p /opt/conga/bin
cat > /opt/conga/bin/update-dashboard.sh << 'DASHSCRIPT'
#!/bin/bash
set -euo pipefail
AWS_REGION=$(ec2-metadata --availability-zone 2>/dev/null | awk '{print substr($2,1,length($2)-1)}')
PROJECT_NAME=$(aws ssm get-parameter --name "/conga/config/setup-manifest" \
  --query "Parameter.Name" --output text --region "$AWS_REGION" 2>/dev/null | cut -d/ -f3)
PROJECT_NAME="conga"

AGENT_PARAMS=$(aws ssm get-parameters-by-path \
  --path "/conga/agents/" \
  --query "Parameters[].Name" \
  --output json --region "$AWS_REGION" 2>/dev/null || echo '[]')

METRICS_SIZE="[]"
METRICS_COUNT="[]"
for NAME in $(echo "$AGENT_PARAMS" | jq -r '.[]' | xargs -I{} basename {}); do
  METRICS_SIZE=$(echo "$METRICS_SIZE" | jq \
    --arg name "$NAME" \
    '. + [["Conga", "SessionSizeKB", "UserId", $name, {"label": $name, "stat": "Maximum", "period": 300}]]')
  METRICS_COUNT=$(echo "$METRICS_COUNT" | jq \
    --arg name "$NAME" \
    '. + [["Conga", "SessionMessageCount", "UserId", $name, {"label": $name, "stat": "Maximum", "period": 300}]]')
done

DASHBOARD_BODY=$(jq -n \
  --argjson size_metrics "$METRICS_SIZE" \
  --argjson count_metrics "$METRICS_COUNT" \
  --arg region "$AWS_REGION" \
  '{widgets: [
    {type: "metric", x: 0, y: 0, width: 12, height: 6, properties: {
      title: "Session Context Size (KB)", view: "timeSeries", stacked: false,
      region: $region, metrics: $size_metrics,
      yAxis: {left: {label: "KB", showUnits: false}}
    }},
    {type: "metric", x: 12, y: 0, width: 12, height: 6, properties: {
      title: "Session Message Count", view: "timeSeries", stacked: false,
      region: $region, metrics: $count_metrics,
      yAxis: {left: {label: "Messages", showUnits: false}}
    }}
  ]}')

aws cloudwatch put-dashboard \
  --dashboard-name "$PROJECT_NAME" \
  --dashboard-body "$DASHBOARD_BODY" \
  --region "$AWS_REGION" 2>/dev/null || echo "WARNING: Failed to update CloudWatch dashboard"

AGENT_COUNT=$(echo "$AGENT_PARAMS" | jq 'length')
echo "CloudWatch dashboard updated with $AGENT_COUNT agents"
DASHSCRIPT
chmod +x /opt/conga/bin/update-dashboard.sh

# Run it now for the bootstrap
/opt/conga/bin/update-dashboard.sh

# ============================================================
# 7. CONFIG INTEGRITY MONITORING
# ============================================================

cat > /opt/conga/scripts/check-config-integrity.sh << 'CHECKSCRIPT'
#!/bin/bash
LOGFILE="/var/log/conga-integrity.log"
TIMESTAMP=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
for HASHFILE in /opt/conga/config/*-config.json.sha256; do
  [ -f "$HASHFILE" ] || continue
  AGENT_NAME=$(basename "$HASHFILE" | sed 's/-config.json.sha256//')
  EXPECTED_HASH=$(cat "$HASHFILE")
  CURRENT_HASH=$(sha256sum "/opt/conga/data/$AGENT_NAME/openclaw.json" | cut -d' ' -f1)
  if [ "$EXPECTED_HASH" != "$CURRENT_HASH" ]; then
    MSG="$TIMESTAMP CONFIG_INTEGRITY_VIOLATION agent=$AGENT_NAME expected=$EXPECTED_HASH actual=$CURRENT_HASH"
    echo "$MSG" >> "$LOGFILE"
    echo "$MSG" | systemd-cat -t conga-integrity -p warning
  else
    MSG="$TIMESTAMP Config integrity OK agent=$AGENT_NAME hash=$CURRENT_HASH"
    echo "$MSG" >> "$LOGFILE"
  fi
done
CHECKSCRIPT
chmod 0755 /opt/conga/scripts/check-config-integrity.sh

cat > /etc/systemd/system/conga-config-check.service << 'CHECKSVC'
[Unit]
Description=Conga Config Integrity Check

[Service]
Type=oneshot
ExecStart=/opt/conga/scripts/check-config-integrity.sh
CHECKSVC

cat > /etc/systemd/system/conga-config-check.timer << CHECKTIMER
[Unit]
Description=Conga Config Integrity Check Timer

[Timer]
OnBootSec=2min
OnUnitActiveSec=${config_check_interval_minutes}min
Persistent=true

[Install]
WantedBy=timers.target
CHECKTIMER

# ============================================================
# 8. SESSION METRICS COLLECTION
# ============================================================

cat > /opt/conga/bin/publish-session-metrics.sh << 'SESSIONMETRICS'
#!/bin/bash
# Publish per-agent session file sizes to CloudWatch
REGION=$(ec2-metadata --availability-zone 2>/dev/null | awk '{print substr($2,1,length($2)-1)}')
REGION=$${REGION:-${aws_region}}

for SESSION_DIR in /opt/conga/data/*/agents/main/sessions; do
  AGENT_NAME=$(echo "$SESSION_DIR" | sed 's|/opt/conga/data/||;s|/agents/main/sessions||')
  [ -z "$AGENT_NAME" ] && continue

  # Find the active session file (largest .jsonl, excluding .reset files)
  ACTIVE_SESSION=$(find "$SESSION_DIR" -maxdepth 1 -name '*.jsonl' ! -name '*.reset.*' -printf '%s %p\n' 2>/dev/null | sort -rn | head -1 | awk '{print $2}')
  [ -z "$ACTIVE_SESSION" ] && continue

  SIZE_BYTES=$(stat -c%s "$ACTIVE_SESSION" 2>/dev/null || echo 0)
  SIZE_KB=$((SIZE_BYTES / 1024))
  LINE_COUNT=$(wc -l < "$ACTIVE_SESSION" 2>/dev/null || echo 0)

  aws cloudwatch put-metric-data \
    --namespace "Conga" \
    --metric-data \
      "[{\"MetricName\":\"SessionSizeKB\",\"Value\":$SIZE_KB,\"Unit\":\"Kilobytes\",\"Dimensions\":[{\"Name\":\"UserId\",\"Value\":\"$AGENT_NAME\"}]},{\"MetricName\":\"SessionMessageCount\",\"Value\":$LINE_COUNT,\"Unit\":\"Count\",\"Dimensions\":[{\"Name\":\"UserId\",\"Value\":\"$AGENT_NAME\"}]}]" \
    --region "$REGION" 2>/dev/null
done
SESSIONMETRICS
chmod +x /opt/conga/bin/publish-session-metrics.sh

cat > /etc/systemd/system/conga-session-metrics.service << 'METRICSSVC'
[Unit]
Description=Publish Conga session metrics to CloudWatch

[Service]
Type=oneshot
ExecStart=/opt/conga/bin/publish-session-metrics.sh
METRICSSVC

cat > /etc/systemd/system/conga-session-metrics.timer << 'METRICSTIMER'
[Unit]
Description=Publish Conga session metrics every 5 minutes

[Timer]
OnBootSec=60
OnUnitActiveSec=300
Persistent=true

[Install]
WantedBy=timers.target
METRICSTIMER

# ============================================================
# 9. CLOUDWATCH AGENT (LOGS)
# ============================================================

dnf install -y amazon-cloudwatch-agent

cat > /opt/aws/amazon-cloudwatch-agent/etc/amazon-cloudwatch-agent.json << 'CWCONFIG'
{
  "agent": {
    "run_as_user": "root"
  },
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/var/log/conga-*.log",
            "log_group_name": "/conga/gateway",
            "log_stream_name": "{instance_id}/container",
            "retention_in_days": 30
          },
          {
            "file_path": "/var/log/conga-integrity.log",
            "log_group_name": "/conga/gateway",
            "log_stream_name": "{instance_id}/integrity",
            "retention_in_days": 30
          }
        ]
      }
    }
  }
}
CWCONFIG

# ============================================================
# 10. START ALL SERVICES
# ============================================================

systemctl daemon-reload

# Config integrity timer
systemctl enable --now conga-config-check.timer

# Session metrics timer
systemctl enable --now conga-session-metrics.timer

# CloudWatch agent
systemctl enable --now amazon-cloudwatch-agent

# Start router FIRST — it connects to Slack
systemctl enable --now conga-router.service
sleep 5

# Connect router to all agent networks
for AGENT_NAME in $ALL_AGENT_NAMES; do
  docker network connect "conga-$AGENT_NAME" conga-router 2>/dev/null || true
done

echo "Router connected to all agent networks"

# Start agent containers sequentially — stagger to avoid resource spikes during image load
for AGENT_NAME in $ALL_AGENT_NAMES; do
  systemctl enable "conga-$AGENT_NAME.service"
  systemctl start "conga-$AGENT_NAME.service"
  echo "Waiting for conga-$AGENT_NAME to stabilize..."
  sleep 30
done

echo "=== Conga Bootstrap Complete: $(date -u) ==="
echo "Router: conga-router (Socket Mode → HTTP forwarding)"
for AGENT_NAME in $ALL_AGENT_NAMES; do
  echo "Agent: $AGENT_NAME (container: conga-$AGENT_NAME)"
done
echo "Check: systemctl status conga-router / conga-<agent_name>"
