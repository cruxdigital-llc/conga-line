#!/bin/bash
set -euo pipefail

exec > >(tee /var/log/openclaw-bootstrap.log) 2>&1
echo "=== OpenClaw Bootstrap Start: $(date -u) ==="

AWS_REGION="${aws_region}"
PROJECT_NAME="${project_name}"
umask 077

# ============================================================
# 1. OS HARDENING
# ============================================================

dnf remove -y openssh-server || true

dnf install -y dnf-automatic
sed -i 's/apply_updates = no/apply_updates = yes/' /etc/dnf/automatic.conf
systemctl enable --now dnf-automatic-install.timer

cat > /etc/sysctl.d/99-openclaw.conf << 'SYSCTL'
net.ipv4.conf.all.send_redirects = 0
net.ipv4.conf.default.send_redirects = 0
net.ipv4.conf.all.accept_redirects = 0
net.ipv4.conf.default.accept_redirects = 0
net.ipv4.tcp_syncookies = 1
net.ipv6.conf.all.disable_ipv6 = 1
net.ipv6.conf.default.disable_ipv6 = 1
SYSCTL
sysctl --system

# ============================================================
# 2. INSTALL DOCKER + NODE.JS + JQ
# ============================================================

dnf install -y docker nodejs npm jq
useradd -m -s /bin/bash openclaw || true
usermod -aG docker openclaw
systemctl enable --now docker

echo "Docker, Node.js, and jq installed"

# ============================================================
# 2b. MOUNT PERSISTENT DATA VOLUME
# ============================================================

DATA_DEVICE="/dev/xvdf"
DATA_MOUNT="/opt/openclaw/data"

while [ ! -b "$DATA_DEVICE" ]; do
  echo "Waiting for data volume to attach..."
  sleep 5
done

if ! blkid "$DATA_DEVICE" | grep -q ext4; then
  echo "Formatting data volume (first time only)"
  mkfs.ext4 "$DATA_DEVICE"
fi

mkdir -p "$DATA_MOUNT"
mountpoint -q "$DATA_MOUNT" || mount "$DATA_DEVICE" "$DATA_MOUNT"

if ! grep -q "$DATA_DEVICE" /etc/fstab; then
  echo "$DATA_DEVICE $DATA_MOUNT ext4 defaults,nofail 0 2" >> /etc/fstab
fi

echo "Data volume mounted at $DATA_MOUNT"

# ============================================================
# 3. SHARED SECRETS
# ============================================================

get_secret() {
  local value
  value=$(aws secretsmanager get-secret-value \
    --secret-id "$1" \
    --query SecretString \
    --output text \
    --region "$AWS_REGION" 2>/dev/null) || true
  echo "$value"
}

# Validate shared secrets — fail fast if admin setup hasn't been run
validate_shared_secrets() {
  local missing=""
  [ -z "$SLACK_BOT_TOKEN" ] && missing="$missing slack-bot-token"
  [ -z "$SLACK_SIGNING_SECRET" ] && missing="$missing slack-signing-secret"
  if [ -n "$missing" ]; then
    echo "FATAL: Required shared secrets not found:$missing"
    echo "Run 'cruxclaw admin setup' before cycling the host."
    exit 1
  fi
}

SLACK_BOT_TOKEN=$(get_secret "openclaw/shared/slack-bot-token")
SLACK_APP_TOKEN=$(get_secret "openclaw/shared/slack-app-token")
SLACK_SIGNING_SECRET=$(get_secret "openclaw/shared/slack-signing-secret")
GOOGLE_CLIENT_ID=$(get_secret "openclaw/shared/google-client-id")
GOOGLE_CLIENT_SECRET=$(get_secret "openclaw/shared/google-client-secret")

validate_shared_secrets
echo "Shared secrets fetched"

# ============================================================
# 4. PULL OPENCLAW IMAGE FROM ECR
# ============================================================

OPENCLAW_IMAGE=$(aws ssm get-parameter --name "/openclaw/config/openclaw-image" \
  --query "Parameter.Value" --output text --region "$AWS_REGION")

# Auto-login to ECR if image is from ECR
ECR_DOMAIN=$(echo "$OPENCLAW_IMAGE" | cut -d'/' -f1)
if [[ "$ECR_DOMAIN" == *".dkr.ecr."* ]]; then
  aws ecr get-login-password --region "$AWS_REGION" | docker login --username AWS --password-stdin "$ECR_DOMAIN"
fi

docker pull "$OPENCLAW_IMAGE"
docker pull node:22-alpine

echo "OpenClaw image pulled"

# ============================================================
# 5. SETUP ROUTER
# ============================================================

mkdir -p /opt/openclaw/{bin,config,scripts,router/src}

# Download router source from S3
aws s3 cp s3://${state_bucket}/openclaw/router/package.json /opt/openclaw/router/package.json --region "$AWS_REGION"
aws s3 cp s3://${state_bucket}/openclaw/router/src/index.js /opt/openclaw/router/src/index.js --region "$AWS_REGION"

# Download behavior files from S3
aws s3 sync s3://${state_bucket}/openclaw/behavior/ /opt/openclaw/behavior/ --region "$AWS_REGION"

# Install router dependencies
cd /opt/openclaw/router && npm install --production
cd /

# routing.json will be generated after agent discovery (section 6)

# Router env file
cat > /opt/openclaw/config/router.env << ROUTERENV
SLACK_APP_TOKEN=$SLACK_APP_TOKEN
SLACK_BOT_TOKEN=$SLACK_BOT_TOKEN
SLACK_SIGNING_SECRET=$SLACK_SIGNING_SECRET
ROUTER_CONFIG=/opt/openclaw/config/routing.json
ROUTERENV
chmod 0400 /opt/openclaw/config/router.env

# Router systemd unit
cat > /etc/systemd/system/openclaw-router.service << 'ROUTERUNIT'
[Unit]
Description=OpenClaw Slack Event Router
After=docker.service
Requires=docker.service

[Service]
Type=simple
EnvironmentFile=/opt/openclaw/config/router.env
ExecStartPre=-/usr/bin/docker rm -f openclaw-router
ExecStart=/usr/bin/docker run --name openclaw-router --cap-drop ALL --security-opt no-new-privileges --memory 128m --cpus 0.25 --pids-limit 64 --read-only -v /opt/openclaw/router:/app:ro -v /opt/openclaw/config/routing.json:/opt/openclaw/config/routing.json:ro -e SLACK_APP_TOKEN -e SLACK_BOT_TOKEN -e SLACK_SIGNING_SECRET -e ROUTER_CONFIG=/opt/openclaw/config/routing.json node:22-alpine node /app/src/index.js
ExecStop=/usr/bin/docker stop openclaw-router
StandardOutput=append:/var/log/openclaw-router.log
StandardError=append:/var/log/openclaw-router.log
Restart=always
RestartSec=5
TimeoutStartSec=60

[Install]
WantedBy=multi-user.target
ROUTERUNIT

echo "Router configured"

# Install behavior deployment helper
cat > /opt/openclaw/bin/deploy-behavior.sh << 'DEPLOY_BEHAVIOR'
#!/bin/bash
set -euo pipefail

AGENT_NAME="$1"
AGENT_TYPE="$2"
STAGING="/opt/openclaw/behavior"
WORKSPACE="/opt/openclaw/data/$AGENT_NAME/data/workspace"

# Read Slack identifier for template substitution
SLACK_ID=$(cat "/opt/openclaw/config/$AGENT_NAME.slack-id" 2>/dev/null || echo "")

# Compose SOUL.md: override > concat(base + type)
if [ -f "$STAGING/overrides/$AGENT_NAME/SOUL.md" ]; then
  cp "$STAGING/overrides/$AGENT_NAME/SOUL.md" "$WORKSPACE/SOUL.md"
elif [ -f "$STAGING/base/SOUL.md" ]; then
  cp "$STAGING/base/SOUL.md" "$WORKSPACE/SOUL.md"
  if [ -f "$STAGING/$AGENT_TYPE/SOUL.md" ]; then
    echo "" >> "$WORKSPACE/SOUL.md"
    cat "$STAGING/$AGENT_TYPE/SOUL.md" >> "$WORKSPACE/SOUL.md"
  fi
fi

# Compose AGENTS.md: override > concat(base + type)
if [ -f "$STAGING/overrides/$AGENT_NAME/AGENTS.md" ]; then
  cp "$STAGING/overrides/$AGENT_NAME/AGENTS.md" "$WORKSPACE/AGENTS.md"
elif [ -f "$STAGING/base/AGENTS.md" ]; then
  cp "$STAGING/base/AGENTS.md" "$WORKSPACE/AGENTS.md"
  if [ -f "$STAGING/$AGENT_TYPE/AGENTS.md" ]; then
    echo "" >> "$WORKSPACE/AGENTS.md"
    cat "$STAGING/$AGENT_TYPE/AGENTS.md" >> "$WORKSPACE/AGENTS.md"
  fi
fi

# Compose USER.md: override > render template
if [ -f "$STAGING/overrides/$AGENT_NAME/USER.md" ]; then
  cp "$STAGING/overrides/$AGENT_NAME/USER.md" "$WORKSPACE/USER.md"
elif [ -f "$STAGING/$AGENT_TYPE/USER.md.tmpl" ]; then
  sed -e "s/{{.AgentName}}/$AGENT_NAME/g" \
      -e "s/{{.SlackChannel}}/$SLACK_ID/g" \
      -e "s/{{.SlackMemberID}}/$SLACK_ID/g" \
      "$STAGING/$AGENT_TYPE/USER.md.tmpl" > "$WORKSPACE/USER.md"
fi

# Fix ownership — container runs as uid 1000 (node)
chown 1000:1000 "$WORKSPACE/SOUL.md" "$WORKSPACE/AGENTS.md" "$WORKSPACE/USER.md" 2>/dev/null || true

echo "Behavior files deployed for $AGENT_NAME ($AGENT_TYPE)"
DEPLOY_BEHAVIOR
chmod +x /opt/openclaw/bin/deploy-behavior.sh

# ============================================================
# 6. DISCOVER AND SETUP AGENTS FROM SSM
# ============================================================

# --- Agent setup functions ---

setup_user_agent() {
  local AGENT_NAME="$1" SLACK_MEMBER_ID="$2" GATEWAY_PORT="$3"

  echo "  Setting up user agent: $AGENT_NAME (slack_member_id: $SLACK_MEMBER_ID, port: $GATEWAY_PORT)"

  # Discover per-agent secrets
  AGENT_SECRET_NAMES=$(aws secretsmanager list-secrets \
    --filter Key=name,Values="openclaw/agents/$AGENT_NAME/" \
    --query 'SecretList[].Name' --output text \
    --region "$AWS_REGION" 2>/dev/null || echo "")

  # Build env file
  cat > /opt/openclaw/config/$AGENT_NAME.env << ENVFILE
SLACK_BOT_TOKEN=$SLACK_BOT_TOKEN
SLACK_SIGNING_SECRET=$SLACK_SIGNING_SECRET
GOOGLE_CLIENT_ID=$GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=$GOOGLE_CLIENT_SECRET
ENVFILE

  if [ -n "$AGENT_SECRET_NAMES" ]; then
    for SECRET_PATH in $AGENT_SECRET_NAMES; do
      SECRET_VALUE=$(get_secret "$SECRET_PATH")
      SECRET_NAME=$(echo "$SECRET_PATH" | sed "s|openclaw/agents/$AGENT_NAME/||" | tr '[:lower:]-' '[:upper:]_')
      echo "$SECRET_NAME=$SECRET_VALUE" >> /opt/openclaw/config/$AGENT_NAME.env
    done
  fi
  chmod 0400 /opt/openclaw/config/$AGENT_NAME.env

  # Generate user-type openclaw.json (DM-only, restricted to owning user)
  cat > /opt/openclaw/config/$AGENT_NAME-openclaw.json << OCCONFIG
{
  "agents": {
    "defaults": {
      "model": { "primary": "anthropic/claude-opus-4-6", "fallbacks": [] },
      "models": { "anthropic/claude-opus-4-6": { "params": {} } },
      "workspace": "/home/node/.openclaw/data/workspace",
      "heartbeat": {
        "every": "55m",
        "lightContext": true,
        "isolatedSession": true,
        "target": "none"
      },
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "5m"
      },
      "compaction": {
        "mode": "safeguard"
      }
    }
  },
  "tools": { "profile": "coding" },
  "commands": { "native": "auto", "nativeSkills": "auto", "restart": true, "ownerDisplay": "raw" },
  "session": { "dmScope": "per-channel-peer" },
  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "command-logger": { "enabled": true },
        "session-memory": { "enabled": true }
      }
    }
  },
  "channels": {
    "slack": {
      "mode": "http",
      "enabled": true,
      "botToken": "$SLACK_BOT_TOKEN",
      "signingSecret": "$SLACK_SIGNING_SECRET",
      "webhookPath": "/slack/events",
      "userTokenReadOnly": true,
      "groupPolicy": "disabled",
      "dmPolicy": "allowlist",
      "allowFrom": ["$SLACK_MEMBER_ID"],
      "dm": { "enabled": true },
      "streaming": "partial",
      "nativeStreaming": true
    }
  },
  "gateway": { "port": 18789, "mode": "local", "bind": "lan" },
  "skills": { "install": { "nodeManager": "pnpm" } },
  "plugins": { "entries": { "slack": { "enabled": true } } }
}
OCCONFIG

  echo "$SLACK_MEMBER_ID" > /opt/openclaw/config/$AGENT_NAME.slack-id
  setup_agent_common "$AGENT_NAME" "$GATEWAY_PORT" "user"
}

setup_team_agent() {
  local AGENT_NAME="$1" SLACK_CHANNEL="$2" GATEWAY_PORT="$3"

  echo "  Setting up team agent: $AGENT_NAME (channel: $SLACK_CHANNEL, port: $GATEWAY_PORT)"

  # Discover per-agent secrets
  AGENT_SECRET_NAMES=$(aws secretsmanager list-secrets \
    --filter Key=name,Values="openclaw/agents/$AGENT_NAME/" \
    --query 'SecretList[].Name' --output text \
    --region "$AWS_REGION" 2>/dev/null || echo "")

  # Build env file
  cat > /opt/openclaw/config/$AGENT_NAME.env << ENVFILE
SLACK_BOT_TOKEN=$SLACK_BOT_TOKEN
SLACK_SIGNING_SECRET=$SLACK_SIGNING_SECRET
GOOGLE_CLIENT_ID=$GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=$GOOGLE_CLIENT_SECRET
ENVFILE

  if [ -n "$AGENT_SECRET_NAMES" ]; then
    for SECRET_PATH in $AGENT_SECRET_NAMES; do
      SECRET_VALUE=$(get_secret "$SECRET_PATH")
      SECRET_NAME=$(echo "$SECRET_PATH" | sed "s|openclaw/agents/$AGENT_NAME/||" | tr '[:lower:]-' '[:upper:]_')
      echo "$SECRET_NAME=$SECRET_VALUE" >> /opt/openclaw/config/$AGENT_NAME.env
    done
  fi
  chmod 0400 /opt/openclaw/config/$AGENT_NAME.env

  # Generate team-type openclaw.json (channel-based, anyone in channel)
  cat > /opt/openclaw/config/$AGENT_NAME-openclaw.json << OCCONFIG
{
  "agents": {
    "defaults": {
      "model": { "primary": "anthropic/claude-opus-4-6", "fallbacks": [] },
      "models": { "anthropic/claude-opus-4-6": { "params": {} } },
      "workspace": "/home/node/.openclaw/data/workspace",
      "heartbeat": {
        "every": "55m",
        "lightContext": true,
        "isolatedSession": true,
        "target": "none"
      },
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "5m"
      },
      "compaction": {
        "mode": "safeguard"
      }
    }
  },
  "tools": { "profile": "coding" },
  "commands": { "native": "auto", "nativeSkills": "auto", "restart": true, "ownerDisplay": "raw" },
  "session": { "dmScope": "per-channel-peer" },
  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "command-logger": { "enabled": true },
        "session-memory": { "enabled": true }
      }
    }
  },
  "channels": {
    "slack": {
      "mode": "http",
      "enabled": true,
      "botToken": "$SLACK_BOT_TOKEN",
      "signingSecret": "$SLACK_SIGNING_SECRET",
      "webhookPath": "/slack/events",
      "userTokenReadOnly": true,
      "groupPolicy": "allowlist",
      "dmPolicy": "disabled",
      "streaming": "partial",
      "nativeStreaming": true,
      "channels": { "$SLACK_CHANNEL": { "allow": true, "requireMention": false } }
    }
  },
  "gateway": { "port": 18789, "mode": "local", "bind": "lan" },
  "skills": { "install": { "nodeManager": "pnpm" } },
  "plugins": { "entries": { "slack": { "enabled": true } } }
}
OCCONFIG

  echo "$SLACK_CHANNEL" > /opt/openclaw/config/$AGENT_NAME.slack-id
  setup_agent_common "$AGENT_NAME" "$GATEWAY_PORT" "team"
}

# Shared setup logic for both agent types
setup_agent_common() {
  local AGENT_NAME="$1" GATEWAY_PORT="$2" AGENT_TYPE="$3"

  # Store agent type for ExecStartPre behavior deployment
  echo "$AGENT_TYPE" > /opt/openclaw/config/$AGENT_NAME.type

  # Create persistent storage
  if [ ! -d /opt/openclaw/data/$AGENT_NAME ]; then
    echo "  Creating new data directory for $AGENT_NAME"
    mkdir -p /opt/openclaw/data/$AGENT_NAME/{workspace,memory,logs,agents,canvas,cron,devices,identity,media}
    chown -R 1000:1000 /opt/openclaw/data/$AGENT_NAME
  fi
  cp /opt/openclaw/config/$AGENT_NAME-openclaw.json /opt/openclaw/data/$AGENT_NAME/openclaw.json
  chown 1000:1000 /opt/openclaw/data/$AGENT_NAME/openclaw.json

  # Deploy behavior files (SOUL.md, AGENTS.md, USER.md) to workspace
  /opt/openclaw/bin/deploy-behavior.sh "$AGENT_NAME" "$AGENT_TYPE"

  # Config hash baseline
  sha256sum /opt/openclaw/config/$AGENT_NAME-openclaw.json | cut -d' ' -f1 > /opt/openclaw/config/$AGENT_NAME-openclaw.json.sha256
  chmod 0444 /opt/openclaw/config/$AGENT_NAME-openclaw.json.sha256

  # Docker network
  docker network create --driver bridge "openclaw-$AGENT_NAME" || true

  # Build -e flags from env file keys
  ENV_FLAGS=""
  while IFS="=" read -r key value; do
    [ -n "$key" ] && ENV_FLAGS="$ENV_FLAGS -e $key"
  done < /opt/openclaw/config/$AGENT_NAME.env

  # Systemd unit
  cat > /etc/systemd/system/openclaw-$AGENT_NAME.service << UNIT
[Unit]
Description=OpenClaw Gateway ($AGENT_NAME)
After=docker.service openclaw-router.service
Requires=docker.service

[Service]
Type=simple
EnvironmentFile=/opt/openclaw/config/$AGENT_NAME.env
ExecStartPre=/bin/bash -c 'aws s3 sync s3://${state_bucket}/openclaw/behavior/ /opt/openclaw/behavior/ --region ${aws_region} 2>/dev/null || true; /opt/openclaw/bin/deploy-behavior.sh $AGENT_NAME \$(cat /opt/openclaw/config/$AGENT_NAME.type 2>/dev/null || echo user) 2>/dev/null || true'
ExecStartPre=-/usr/bin/docker rm -f openclaw-$AGENT_NAME
ExecStart=/usr/bin/docker run --name openclaw-$AGENT_NAME --network openclaw-$AGENT_NAME -p 127.0.0.1:$GATEWAY_PORT:18789 --cap-drop ALL --security-opt no-new-privileges --memory 2g --cpus 1.5 -e NODE_OPTIONS="--max-old-space-size=1536" --pids-limit 256 -v /opt/openclaw/data/$AGENT_NAME:/home/node/.openclaw:rw $ENV_FLAGS $OPENCLAW_IMAGE
ExecStop=/usr/bin/docker stop openclaw-$AGENT_NAME
StandardOutput=append:/var/log/openclaw-$AGENT_NAME.log
StandardError=append:/var/log/openclaw-$AGENT_NAME.log
Restart=always
RestartSec=10
TimeoutStartSec=120
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
UNIT

  echo "  Agent $AGENT_NAME configured"
}

# --- Stop any existing agent containers from prior bootstraps ---
# Prevents port conflicts when agent names change (e.g. migration from member_id to name)

for OLD_UNIT in /etc/systemd/system/openclaw-*.service; do
  [ -f "$OLD_UNIT" ] || continue
  UNIT_NAME=$(basename "$OLD_UNIT" .service)
  [ "$UNIT_NAME" = "openclaw-router" ] && continue
  echo "Stopping previous agent: $UNIT_NAME"
  systemctl stop "$UNIT_NAME" 2>/dev/null || true
  docker rm -f "$UNIT_NAME" 2>/dev/null || true
  systemctl disable "$UNIT_NAME" 2>/dev/null || true
  rm -f "$OLD_UNIT"
done
systemctl daemon-reload

# --- Discover all agents from SSM ---

AGENT_PARAMS=$(aws ssm get-parameters-by-path \
  --path "/openclaw/agents/" \
  --query "Parameters" \
  --output json --region "$AWS_REGION" 2>&1) || {
  echo "FATAL: Failed to query agents from SSM: $AGENT_PARAMS"
  echo "Check IAM permissions for ssm:GetParametersByPath on /openclaw/agents/"
  exit 1
}

ROUTING_CHANNELS="{}"
ROUTING_MEMBERS="{}"
ALL_AGENT_NAMES=""

for PARAM in $(echo "$AGENT_PARAMS" | jq -r '.[] | @base64'); do
  PARAM_JSON=$(echo "$PARAM" | base64 -d)
  AGENT_NAME=$(echo "$PARAM_JSON" | jq -r '.Name' | xargs basename)
  PARAM_VALUE=$(echo "$PARAM_JSON" | jq -r '.Value')
  AGENT_TYPE=$(echo "$PARAM_VALUE" | jq -r '.type // empty')
  GATEWAY_PORT=$(echo "$PARAM_VALUE" | jq -r '.gateway_port')

  if [ -z "$AGENT_TYPE" ]; then
    echo "WARNING: Agent $AGENT_NAME has no type field, skipping"
    continue
  fi

  echo "=== Setting up agent: $AGENT_NAME (type: $AGENT_TYPE) ==="

  if [ "$AGENT_TYPE" = "user" ]; then
    SLACK_MEMBER_ID=$(echo "$PARAM_VALUE" | jq -r '.slack_member_id')
    setup_user_agent "$AGENT_NAME" "$SLACK_MEMBER_ID" "$GATEWAY_PORT"
    ROUTING_MEMBERS=$(echo "$ROUTING_MEMBERS" | jq \
      --arg k "$SLACK_MEMBER_ID" \
      --arg v "http://openclaw-$AGENT_NAME:18789/slack/events" \
      '. + {($k): $v}')
  elif [ "$AGENT_TYPE" = "team" ]; then
    SLACK_CHANNEL=$(echo "$PARAM_VALUE" | jq -r '.slack_channel')
    setup_team_agent "$AGENT_NAME" "$SLACK_CHANNEL" "$GATEWAY_PORT"
    ROUTING_CHANNELS=$(echo "$ROUTING_CHANNELS" | jq \
      --arg k "$SLACK_CHANNEL" \
      --arg v "http://openclaw-$AGENT_NAME:18789/slack/events" \
      '. + {($k): $v}')
  else
    echo "WARNING: Unknown agent type '$AGENT_TYPE' for $AGENT_NAME, skipping"
    continue
  fi

  ALL_AGENT_NAMES="$ALL_AGENT_NAMES $AGENT_NAME"
done

# Write routing.json
jq -n --argjson channels "$ROUTING_CHANNELS" --argjson members "$ROUTING_MEMBERS" \
  '{"channels": $channels, "members": $members}' > /opt/openclaw/config/routing.json

if [ -z "$(echo "$ALL_AGENT_NAMES" | tr -d ' ')" ]; then
  echo "WARNING: No agents found in SSM. Router will start with empty routing config."
fi

# --- Install dashboard update helper ---
# Called by bootstrap and by CLI add-user/add-team scripts
mkdir -p /opt/openclaw/bin
cat > /opt/openclaw/bin/update-dashboard.sh << 'DASHSCRIPT'
#!/bin/bash
set -euo pipefail
AWS_REGION=$(ec2-metadata --availability-zone 2>/dev/null | awk '{print substr($2,1,length($2)-1)}')
PROJECT_NAME=$(aws ssm get-parameter --name "/openclaw/config/setup-manifest" \
  --query "Parameter.Name" --output text --region "$AWS_REGION" 2>/dev/null | cut -d/ -f3)
PROJECT_NAME="openclaw"

AGENT_PARAMS=$(aws ssm get-parameters-by-path \
  --path "/openclaw/agents/" \
  --query "Parameters[].Name" \
  --output json --region "$AWS_REGION" 2>/dev/null || echo '[]')

METRICS_SIZE="[]"
METRICS_COUNT="[]"
for NAME in $(echo "$AGENT_PARAMS" | jq -r '.[]' | xargs -I{} basename {}); do
  METRICS_SIZE=$(echo "$METRICS_SIZE" | jq \
    --arg name "$NAME" \
    '. + [["OpenClaw", "SessionSizeKB", "UserId", $name, {"label": $name, "stat": "Maximum", "period": 300}]]')
  METRICS_COUNT=$(echo "$METRICS_COUNT" | jq \
    --arg name "$NAME" \
    '. + [["OpenClaw", "SessionMessageCount", "UserId", $name, {"label": $name, "stat": "Maximum", "period": 300}]]')
done

DASHBOARD_BODY=$(jq -n \
  --argjson size_metrics "$METRICS_SIZE" \
  --argjson count_metrics "$METRICS_COUNT" \
  --arg region "$AWS_REGION" \
  '{widgets: [
    {type: "metric", x: 0, y: 0, width: 12, height: 6, properties: {
      title: "Session Context Size (KB)", view: "timeSeries", stacked: false,
      region: $region, metrics: $size_metrics,
      yAxis: {left: {label: "KB", showUnits: false}}
    }},
    {type: "metric", x: 12, y: 0, width: 12, height: 6, properties: {
      title: "Session Message Count", view: "timeSeries", stacked: false,
      region: $region, metrics: $count_metrics,
      yAxis: {left: {label: "Messages", showUnits: false}}
    }}
  ]}')

aws cloudwatch put-dashboard \
  --dashboard-name "$PROJECT_NAME" \
  --dashboard-body "$DASHBOARD_BODY" \
  --region "$AWS_REGION" 2>/dev/null || echo "WARNING: Failed to update CloudWatch dashboard"

AGENT_COUNT=$(echo "$AGENT_PARAMS" | jq 'length')
echo "CloudWatch dashboard updated with $AGENT_COUNT agents"
DASHSCRIPT
chmod +x /opt/openclaw/bin/update-dashboard.sh

# Run it now for the bootstrap
/opt/openclaw/bin/update-dashboard.sh

# ============================================================
# 7. CONFIG INTEGRITY MONITORING
# ============================================================

cat > /opt/openclaw/scripts/check-config-integrity.sh << 'CHECKSCRIPT'
#!/bin/bash
LOGFILE="/var/log/openclaw-integrity.log"
TIMESTAMP=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
for HASHFILE in /opt/openclaw/config/*-openclaw.json.sha256; do
  [ -f "$HASHFILE" ] || continue
  AGENT_NAME=$(basename "$HASHFILE" | sed 's/-openclaw.json.sha256//')
  EXPECTED_HASH=$(cat "$HASHFILE")
  CURRENT_HASH=$(sha256sum "/opt/openclaw/data/$AGENT_NAME/openclaw.json" | cut -d' ' -f1)
  if [ "$EXPECTED_HASH" != "$CURRENT_HASH" ]; then
    MSG="$TIMESTAMP CONFIG_INTEGRITY_VIOLATION agent=$AGENT_NAME expected=$EXPECTED_HASH actual=$CURRENT_HASH"
    echo "$MSG" >> "$LOGFILE"
    echo "$MSG" | systemd-cat -t openclaw-integrity -p warning
  else
    MSG="$TIMESTAMP Config integrity OK agent=$AGENT_NAME hash=$CURRENT_HASH"
    echo "$MSG" >> "$LOGFILE"
  fi
done
CHECKSCRIPT
chmod 0755 /opt/openclaw/scripts/check-config-integrity.sh

cat > /etc/systemd/system/openclaw-config-check.service << 'CHECKSVC'
[Unit]
Description=OpenClaw Config Integrity Check

[Service]
Type=oneshot
ExecStart=/opt/openclaw/scripts/check-config-integrity.sh
CHECKSVC

cat > /etc/systemd/system/openclaw-config-check.timer << CHECKTIMER
[Unit]
Description=OpenClaw Config Integrity Check Timer

[Timer]
OnBootSec=2min
OnUnitActiveSec=${config_check_interval_minutes}min
Persistent=true

[Install]
WantedBy=timers.target
CHECKTIMER

# ============================================================
# 8. SESSION METRICS COLLECTION
# ============================================================

cat > /opt/openclaw/bin/publish-session-metrics.sh << 'SESSIONMETRICS'
#!/bin/bash
# Publish per-agent session file sizes to CloudWatch
REGION=$(ec2-metadata --availability-zone 2>/dev/null | awk '{print substr($2,1,length($2)-1)}')
REGION=$${REGION:-${aws_region}}

for SESSION_DIR in /opt/openclaw/data/*/agents/main/sessions; do
  AGENT_NAME=$(echo "$SESSION_DIR" | sed 's|/opt/openclaw/data/||;s|/agents/main/sessions||')
  [ -z "$AGENT_NAME" ] && continue

  # Find the active session file (largest .jsonl, excluding .reset files)
  ACTIVE_SESSION=$(find "$SESSION_DIR" -maxdepth 1 -name '*.jsonl' ! -name '*.reset.*' -printf '%s %p\n' 2>/dev/null | sort -rn | head -1 | awk '{print $2}')
  [ -z "$ACTIVE_SESSION" ] && continue

  SIZE_BYTES=$(stat -c%s "$ACTIVE_SESSION" 2>/dev/null || echo 0)
  SIZE_KB=$((SIZE_BYTES / 1024))
  LINE_COUNT=$(wc -l < "$ACTIVE_SESSION" 2>/dev/null || echo 0)

  aws cloudwatch put-metric-data \
    --namespace "OpenClaw" \
    --metric-data \
      "[{\"MetricName\":\"SessionSizeKB\",\"Value\":$SIZE_KB,\"Unit\":\"Kilobytes\",\"Dimensions\":[{\"Name\":\"UserId\",\"Value\":\"$AGENT_NAME\"}]},{\"MetricName\":\"SessionMessageCount\",\"Value\":$LINE_COUNT,\"Unit\":\"Count\",\"Dimensions\":[{\"Name\":\"UserId\",\"Value\":\"$AGENT_NAME\"}]}]" \
    --region "$REGION" 2>/dev/null
done
SESSIONMETRICS
chmod +x /opt/openclaw/bin/publish-session-metrics.sh

cat > /etc/systemd/system/openclaw-session-metrics.service << 'METRICSSVC'
[Unit]
Description=Publish OpenClaw session metrics to CloudWatch

[Service]
Type=oneshot
ExecStart=/opt/openclaw/bin/publish-session-metrics.sh
METRICSSVC

cat > /etc/systemd/system/openclaw-session-metrics.timer << 'METRICSTIMER'
[Unit]
Description=Publish OpenClaw session metrics every 5 minutes

[Timer]
OnBootSec=60
OnUnitActiveSec=300
Persistent=true

[Install]
WantedBy=timers.target
METRICSTIMER

# ============================================================
# 9. CLOUDWATCH AGENT (LOGS)
# ============================================================

dnf install -y amazon-cloudwatch-agent

cat > /opt/aws/amazon-cloudwatch-agent/etc/amazon-cloudwatch-agent.json << 'CWCONFIG'
{
  "agent": {
    "run_as_user": "root"
  },
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/var/log/openclaw-*.log",
            "log_group_name": "/openclaw/gateway",
            "log_stream_name": "{instance_id}/container",
            "retention_in_days": 30
          },
          {
            "file_path": "/var/log/openclaw-integrity.log",
            "log_group_name": "/openclaw/gateway",
            "log_stream_name": "{instance_id}/integrity",
            "retention_in_days": 30
          }
        ]
      }
    }
  }
}
CWCONFIG

# ============================================================
# 10. START ALL SERVICES
# ============================================================

systemctl daemon-reload

# Config integrity timer
systemctl enable --now openclaw-config-check.timer

# Session metrics timer
systemctl enable --now openclaw-session-metrics.timer

# CloudWatch agent
systemctl enable --now amazon-cloudwatch-agent

# Start router FIRST — it connects to Slack
systemctl enable --now openclaw-router.service
sleep 5

# Connect router to all agent networks
for AGENT_NAME in $ALL_AGENT_NAMES; do
  docker network connect "openclaw-$AGENT_NAME" openclaw-router 2>/dev/null || true
done

echo "Router connected to all agent networks"

# Start agent containers
for AGENT_NAME in $ALL_AGENT_NAMES; do
  systemctl enable "openclaw-$AGENT_NAME.service"
  systemctl start "openclaw-$AGENT_NAME.service"
done

echo "=== OpenClaw Bootstrap Complete: $(date -u) ==="
echo "Router: openclaw-router (Socket Mode → HTTP forwarding)"
for AGENT_NAME in $ALL_AGENT_NAMES; do
  echo "Agent: $AGENT_NAME (container: openclaw-$AGENT_NAME)"
done
echo "Check: systemctl status openclaw-router / openclaw-<agent_name>"
