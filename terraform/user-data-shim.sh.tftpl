#!/bin/bash
set -euxo pipefail
exec > >(tee /var/log/openclaw-bootstrap.log) 2>&1

# Download and run the full bootstrap script from S3
aws s3 cp s3://openclaw-terraform-state-123456789012/openclaw/bootstrap/bootstrap.sh /tmp/bootstrap.sh --region ${aws_region}
chmod +x /tmp/bootstrap.sh
/tmp/bootstrap.sh
