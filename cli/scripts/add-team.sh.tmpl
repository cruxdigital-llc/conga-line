set -euo pipefail
umask 077
AGENT_NAME="{{.AgentName}}"
SLACK_CHANNEL="{{.SlackChannel}}"
AWS_REGION="{{.AWSRegion}}"
GATEWAY_PORT="{{.GatewayPort}}"

get_secret() {
  aws secretsmanager get-secret-value \
    --secret-id "$1" --query SecretString --output text --region "$AWS_REGION"
}

CONGA_IMAGE=$(aws ssm get-parameter --name "/conga/config/image" \
  --query "Parameter.Value" --output text --region "$AWS_REGION")

echo "=== Setting up team agent: $AGENT_NAME ==="

SLACK_BOT_TOKEN=$(get_secret "conga/shared/slack-bot-token")
SLACK_SIGNING_SECRET=$(get_secret "conga/shared/slack-signing-secret")
GOOGLE_CLIENT_ID=$(get_secret "conga/shared/google-client-id")
GOOGLE_CLIENT_SECRET=$(get_secret "conga/shared/google-client-secret")

# Discover per-agent secrets
AGENT_SECRET_NAMES=$(aws secretsmanager list-secrets \
  --filter Key=name,Values="conga/agents/$AGENT_NAME/" \
  --query 'SecretList[].Name' --output text \
  --region "$AWS_REGION" 2>/dev/null || echo "")

cat > /opt/conga/config/$AGENT_NAME.env << ENVFILE
SLACK_BOT_TOKEN=$SLACK_BOT_TOKEN
SLACK_SIGNING_SECRET=$SLACK_SIGNING_SECRET
GOOGLE_CLIENT_ID=$GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=$GOOGLE_CLIENT_SECRET
ENVFILE

if [ -n "$AGENT_SECRET_NAMES" ]; then
  for SECRET_PATH in $AGENT_SECRET_NAMES; do
    SECRET_VALUE=$(get_secret "$SECRET_PATH")
    SECRET_NAME=$(echo "$SECRET_PATH" | sed "s|conga/agents/$AGENT_NAME/||" | tr '[:lower:]-' '[:upper:]_')
    echo "$SECRET_NAME=$SECRET_VALUE" >> /opt/conga/config/$AGENT_NAME.env
  done
fi
chmod 0400 /opt/conga/config/$AGENT_NAME.env

cat > /opt/conga/config/$AGENT_NAME-config.json << OCCONFIG
{
  "agents": {
    "defaults": {
      "model": { "primary": "anthropic/claude-opus-4-6", "fallbacks": [] },
      "models": { "anthropic/claude-opus-4-6": { "params": {} } },
      "workspace": "/home/node/.openclaw/data/workspace",
      "heartbeat": {
        "every": "55m",
        "lightContext": true,
        "target": "none"
      },
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "5m"
      },
      "compaction": {
        "mode": "safeguard"
      }
    }
  },
  "tools": { "profile": "coding" },
  "commands": { "native": "auto", "nativeSkills": "auto", "restart": true, "ownerDisplay": "raw" },
  "session": { "dmScope": "per-channel-peer" },
  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "command-logger": { "enabled": true },
        "session-memory": { "enabled": true }
      }
    }
  },
  "channels": {
    "slack": {
      "mode": "http",
      "enabled": true,
      "botToken": "$SLACK_BOT_TOKEN",
      "signingSecret": "$SLACK_SIGNING_SECRET",
      "webhookPath": "/slack/events",
      "userTokenReadOnly": true,
      "groupPolicy": "allowlist",
      "dmPolicy": "disabled",
      "streaming": "partial",
      "nativeStreaming": true,
      "channels": { "$SLACK_CHANNEL": { "allow": true, "requireMention": false } }
    }
  },
  "gateway": { "port": 18789, "mode": "local", "bind": "lan", "controlUi": { "allowedOrigins": ["http://localhost:${GATEWAY_PORT}"] } },
  "skills": { "install": { "nodeManager": "pnpm" } },
  "plugins": { "entries": { "slack": { "enabled": true } } }
}
OCCONFIG

mkdir -p /opt/conga/data/$AGENT_NAME/data/{workspace,memory,logs,agents,canvas,cron,devices,identity,media}
chown -R 1000:1000 /opt/conga/data/$AGENT_NAME
cp /opt/conga/config/$AGENT_NAME-config.json /opt/conga/data/$AGENT_NAME/openclaw.json
chown 1000:1000 /opt/conga/data/$AGENT_NAME/openclaw.json

sha256sum /opt/conga/config/$AGENT_NAME-config.json | cut -d' ' -f1 > /opt/conga/config/$AGENT_NAME-config.json.sha256
chmod 0444 /opt/conga/config/$AGENT_NAME-config.json.sha256

# Store agent metadata for behavior deployment
echo "team" > /opt/conga/config/$AGENT_NAME.type
echo "$SLACK_CHANNEL" > /opt/conga/config/$AGENT_NAME.slack-id

# Sync and deploy behavior files
aws s3 sync "s3://{{.StateBucket}}/conga/behavior/" /opt/conga/behavior/ --region "$AWS_REGION" 2>/dev/null || true
if [ -x /opt/conga/bin/deploy-behavior.sh ]; then
  /opt/conga/bin/deploy-behavior.sh "$AGENT_NAME" "team"
fi

docker network create --driver bridge "conga-$AGENT_NAME" || true

# Deploy egress proxy (deny-all when no policy, enforce by default)
EGRESS_MODE="{{.EgressMode}}"
EGRESS_CONF="/opt/conga/config/egress-$AGENT_NAME.yaml"
EGRESS_PROXY="conga-egress-$AGENT_NAME"
BOOTSTRAP_PATH="/opt/conga/config/proxy-bootstrap.js"

cat > "$EGRESS_CONF" << 'ENVOYEOF'
{{.EnvoyConfig}}
ENVOYEOF
chmod 0444 "$EGRESS_CONF"

cat > "$BOOTSTRAP_PATH" << 'BOOTSTRAPEOF'
{{.ProxyBootstrapJS}}
BOOTSTRAPEOF
chmod 0444 "$BOOTSTRAP_PATH"

echo "$EGRESS_MODE" > "/opt/conga/config/egress-$AGENT_NAME.mode"

if ! docker image inspect conga-egress-proxy >/dev/null 2>&1; then
  echo "Building egress proxy image..."
  mkdir -p /tmp/conga-egress-build
  cat > /tmp/conga-egress-build/Dockerfile << 'PROXYDF'
FROM envoyproxy/envoy:v1.32-latest
PROXYDF
  docker build -t conga-egress-proxy /tmp/conga-egress-build
  rm -rf /tmp/conga-egress-build
fi

docker rm -f "$EGRESS_PROXY" 2>/dev/null || true
docker run -d \
  --name "$EGRESS_PROXY" \
  --network "conga-$AGENT_NAME" \
  --restart always \
  --cap-drop ALL \
  --security-opt no-new-privileges \
  --memory 128m \
  --user 101:101 \
  --entrypoint /usr/local/bin/envoy \
  -v "$EGRESS_CONF:/etc/envoy/envoy.yaml:ro" \
  conga-egress-proxy \
  -c /etc/envoy/envoy.yaml --log-level warn

# Verify proxy started
for i in $(seq 1 5); do
  if docker inspect -f '{{`{{.State.Running}}`}}' "$EGRESS_PROXY" 2>/dev/null | grep -q true; then
    break
  fi
  sleep 1
done
if ! docker inspect -f '{{`{{.State.Running}}`}}' "$EGRESS_PROXY" 2>/dev/null | grep -q true; then
  echo "FATAL: Egress proxy $EGRESS_PROXY failed to start"
  docker logs "$EGRESS_PROXY" 2>&1 | tail -20 || true
  exit 1
fi
echo "Egress proxy started for $AGENT_NAME (mode=$EGRESS_MODE)"

ENV_FLAGS=""
while IFS="=" read -r key value; do
  [ -n "$key" ] && ENV_FLAGS="$ENV_FLAGS -e $key"
done < /opt/conga/config/$AGENT_NAME.env

cat > /etc/systemd/system/conga-$AGENT_NAME.service << UNIT
[Unit]
Description=OpenClaw Gateway ($AGENT_NAME)
After=docker.service conga-router.service
Requires=docker.service

[Service]
Type=simple
EnvironmentFile=/opt/conga/config/$AGENT_NAME.env
ExecStartPre=-/usr/bin/docker rm -f conga-$AGENT_NAME
ExecStart=/usr/bin/docker run --name conga-$AGENT_NAME --network conga-$AGENT_NAME -p 127.0.0.1:${GATEWAY_PORT}:18789 --cap-drop ALL --security-opt no-new-privileges --memory 2g -e NODE_OPTIONS="--max-old-space-size=1536 --require /opt/proxy-bootstrap.js" -e HTTPS_PROXY=http://$EGRESS_PROXY:3128 -e HTTP_PROXY=http://$EGRESS_PROXY:3128 -e NO_PROXY=localhost,127.0.0.1 --pids-limit 256 -v /opt/conga/data/$AGENT_NAME:/home/node/.openclaw:rw -v $BOOTSTRAP_PATH:/opt/proxy-bootstrap.js:ro $ENV_FLAGS $CONGA_IMAGE
ExecStartPost=-/usr/bin/docker network connect conga-$AGENT_NAME conga-router
ExecStop=/usr/bin/docker stop conga-$AGENT_NAME
StandardOutput=append:/var/log/conga-$AGENT_NAME.log
StandardError=append:/var/log/conga-$AGENT_NAME.log
Restart=always
RestartSec=10
TimeoutStartSec=120
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
UNIT

systemctl daemon-reload
systemctl enable conga-$AGENT_NAME.service
systemctl start conga-$AGENT_NAME.service

# Apply iptables egress enforcement (enforce mode only)
if [ "$EGRESS_MODE" = "enforce" ]; then
  for i in $(seq 1 10); do
    AGENT_IP=$(docker inspect -f "{{`{{(index .NetworkSettings.Networks \"conga-$AGENT_NAME\").IPAddress}}`}}" "conga-$AGENT_NAME" 2>/dev/null || echo "")
    [ -n "$AGENT_IP" ] && break
    sleep 1
  done
  NET_CIDR=$(docker network inspect -f '{{`{{range .IPAM.Config}}{{.Subnet}}{{end}}`}}' "conga-$AGENT_NAME" 2>/dev/null || echo "")
  if [ -n "$AGENT_IP" ] && [ -n "$NET_CIDR" ]; then
    iptables -C DOCKER-USER -s "$AGENT_IP" -j DROP 2>/dev/null || \
      iptables -I DOCKER-USER -s "$AGENT_IP" -j DROP
    iptables -C DOCKER-USER -s "$AGENT_IP" -d "$NET_CIDR" -j RETURN 2>/dev/null || \
      iptables -I DOCKER-USER -s "$AGENT_IP" -d "$NET_CIDR" -j RETURN
    iptables -C DOCKER-USER -s "$AGENT_IP" -m conntrack --ctstate ESTABLISHED,RELATED -j RETURN 2>/dev/null || \
      iptables -I DOCKER-USER -s "$AGENT_IP" -m conntrack --ctstate ESTABLISHED,RELATED -j RETURN
    echo "Egress iptables: DROP rules applied for $AGENT_NAME ($AGENT_IP)"
  else
    echo "ERROR: Could not apply egress iptables rules — container IP ($AGENT_IP) or subnet ($NET_CIDR) not found"
    exit 1
  fi
fi

# Update routing config with the team's channel entry (channel routing only)
# Initialize routing.json if it does not exist (first agent on fresh host)
[ -f /opt/conga/config/routing.json ] || echo '{"channels":{},"members":{}}' > /opt/conga/config/routing.json
node -e "
  const fs = require('fs');
  const cfg = JSON.parse(fs.readFileSync('/opt/conga/config/routing.json', 'utf-8'));
  cfg.channels['$SLACK_CHANNEL'] = 'http://conga-$AGENT_NAME:18789/slack/events';
  fs.writeFileSync('/opt/conga/config/routing.json', JSON.stringify(cfg, null, 2));
"

# Connect router to the agent's network
docker network connect "conga-$AGENT_NAME" conga-router 2>/dev/null || true

# Update CloudWatch dashboard with all agents
/opt/conga/bin/update-dashboard.sh || echo "WARNING: Dashboard update failed"

echo "=== Team agent $AGENT_NAME setup complete ==="
